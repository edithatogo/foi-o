    <sequenceFlow id="Flow_015" sourceRef="State_ExtensionApplied" targetRef="State_DecisionDrafting"/>
    <sequenceFlow id="Flow_016" sourceRef="State_ExtensionApplied" targetRef="State_DocumentsIdentified"/>
    <sequenceFlow id="Flow_017" sourceRef="State_ExtensionApplied" targetRef="State_HumanDecisionRequired"/>
    <sequenceFlow id="Flow_018" sourceRef="State_ExtensionApplied" targetRef="State_SearchPlanning"/>
    <sequenceFlow id="Flow_019" sourceRef="State_ExtensionApplied" targetRef="State_Searching"/>
    <sequenceFlow id="Flow_020" sourceRef="State_HumanDecisionRequired" targetRef="State_DecisionApproved"/>
    <sequenceFlow id="Flow_021" sourceRef="State_Received" targetRef="State_Acknowledged"/>
    <sequenceFlow id="Flow_022" sourceRef="State_Received" targetRef="State_AwaitingClarification"/>
