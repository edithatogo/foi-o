    <sequenceFlow id="Flow_End_ReleasedInFull" sourceRef="State_ReleasedInFull" targetRef="End_StateMachine"/>
    <sequenceFlow id="Flow_End_ReleasedInPart" sourceRef="State_ReleasedInPart" targetRef="End_StateMachine"/>
    <sequenceFlow id="Flow_End_Withdrawn" sourceRef="State_Withdrawn" targetRef="End_StateMachine"/>
