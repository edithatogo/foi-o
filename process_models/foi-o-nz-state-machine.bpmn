    <task id="State_TransferredInFull" name="TransferredInFull"/>
    <task id="State_ValidityChecking" name="ValidityChecking"/>
    <task id="State_Withdrawn" name="Withdrawn"/>
    <sequenceFlow id="Flow_Start_Drafted" sourceRef="Start_StateMachine" targetRef="State_Drafted"/>
    <sequenceFlow id="Flow_001" sourceRef="State_ChargeAssessment" targetRef="State_DecisionDrafting"/>
    <sequenceFlow id="Flow_002" sourceRef="State_ChargeAssessment" targetRef="State_SearchPlanning"/>
    <sequenceFlow id="Flow_003" sourceRef="State_ChargeAssessment" targetRef="State_Searching"/>
    <sequenceFlow id="Flow_004" sourceRef="State_ChargeAssessment" targetRef="State_Withdrawn"/>
    <sequenceFlow id="Flow_005" sourceRef="State_DecisionApproved" targetRef="State_Refused"/>
    <sequenceFlow id="Flow_006" sourceRef="State_DecisionApproved" targetRef="State_ReleasedInFull"/>
    <sequenceFlow id="Flow_007" sourceRef="State_DecisionApproved" targetRef="State_ReleasedInPart"/>
    <sequenceFlow id="Flow_008" sourceRef="State_DecisionDrafting" targetRef="State_HumanDecisionRequired"/>
    <sequenceFlow id="Flow_009" sourceRef="State_DocumentsIdentified" targetRef="State_ConsultationRequired"/>
