    <sequenceFlow id="Flow_028" sourceRef="State_Received" targetRef="State_Withdrawn"/>
    <sequenceFlow id="Flow_029" sourceRef="State_SearchPlanning" targetRef="State_ConsultationRequired"/>
    <sequenceFlow id="Flow_030" sourceRef="State_SearchPlanning" targetRef="State_Searching"/>
    <sequenceFlow id="Flow_031" sourceRef="State_Searching" targetRef="State_ChargeAssessment"/>
