<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
  id="Definitions_FOIO_NZ_StateMachine"
  targetNamespace="https://w3id.org/foio-nz/process/bpmn/state-machine">
  <process id="Process_FOIO_NZ_StateMachine" name="FOI-O NZ canonical state transitions" isExecutable="false">
    <startEvent id="Start_StateMachine" name="Start"/>
    <endEvent id="End_StateMachine" name="End"/>
    <task id="State_Acknowledged" name="Acknowledged"/>
    <task id="State_AwaitingClarification" name="AwaitingClarification"/>
    <task id="State_ChargeAssessment" name="ChargeAssessment"/>
    <task id="State_Closed" name="Closed"/>
    <task id="State_ConsultationRequired" name="ConsultationRequired"/>
    <task id="State_DecisionApproved" name="DecisionApproved"/>
    <task id="State_DecisionDrafting" name="DecisionDrafting"/>
    <task id="State_DocumentsIdentified" name="DocumentsIdentified"/>
    <task id="State_Drafted" name="Drafted"/>
    <task id="State_ExtensionApplied" name="ExtensionApplied"/>
    <task id="State_HumanDecisionRequired" name="HumanDecisionRequired"/>
    <task id="State_NoDocumentsFound" name="NoDocumentsFound"/>
    <task id="State_Received" name="Received"/>
    <task id="State_Refused" name="Refused"/>
    <task id="State_ReleasedInFull" name="ReleasedInFull"/>
    <task id="State_ReleasedInPart" name="ReleasedInPart"/>
    <task id="State_SearchPlanning" name="SearchPlanning"/>
