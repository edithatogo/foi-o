@prefix foio-state: <https://w3id.org/foio-nz/state/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

foio-state:scheme a skos:ConceptScheme ;
  dcterms:title "FOI-O NZ normalised request states" ;
  dcterms:description "Normalised OIA lifecycle states. Source FYI/Alaveteli states must be preserved separately." .

foio-state:observed a skos:Concept ; skos:prefLabel "observed" ; skos:inScheme foio-state:scheme .
foio-state:submitted a skos:Concept ; skos:prefLabel "submitted" ; skos:inScheme foio-state:scheme .
foio-state:awaiting_response a skos:Concept ; skos:prefLabel "awaiting response" ; skos:inScheme foio-state:scheme .
foio-state:awaiting_clarification a skos:Concept ; skos:prefLabel "awaiting clarification" ; skos:inScheme foio-state:scheme .
foio-state:scope_amended a skos:Concept ; skos:prefLabel "scope amended" ; skos:inScheme foio-state:scheme .
foio-state:transferred a skos:Concept ; skos:prefLabel "transferred" ; skos:inScheme foio-state:scheme .
foio-state:extension_notified a skos:Concept ; skos:prefLabel "extension notified" ; skos:inScheme foio-state:scheme .
foio-state:decision_communicated a skos:Concept ; skos:prefLabel "decision communicated" ; skos:inScheme foio-state:scheme .
foio-state:released_in_full a skos:Concept ; skos:prefLabel "released in full" ; skos:inScheme foio-state:scheme .
foio-state:released_in_part a skos:Concept ; skos:prefLabel "released in part" ; skos:inScheme foio-state:scheme .
foio-state:refused a skos:Concept ; skos:prefLabel "refused" ; skos:definition "A refusal has been communicated or inferred; exact statutory meaning requires evidence." ; skos:inScheme foio-state:scheme .
foio-state:information_not_held a skos:Concept ; skos:prefLabel "information not held" ; skos:inScheme foio-state:scheme .
foio-state:withdrawn a skos:Concept ; skos:prefLabel "withdrawn" ; skos:inScheme foio-state:scheme .
foio-state:overdue a skos:Concept ; skos:prefLabel "overdue" ; skos:definition "Appears overdue from public-platform data; agency clock status may differ." ; skos:inScheme foio-state:scheme .
foio-state:complaint_observed a skos:Concept ; skos:prefLabel "complaint observed" ; skos:inScheme foio-state:scheme .
foio-state:closed a skos:Concept ; skos:prefLabel "closed" ; skos:inScheme foio-state:scheme .
foio-state:unknown a skos:Concept ; skos:prefLabel "unknown" ; skos:inScheme foio-state:scheme .
