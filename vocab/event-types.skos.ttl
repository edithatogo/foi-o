@prefix foio-event: <https://w3id.org/foio-nz/event-type/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

foio-event:scheme a skos:ConceptScheme ;
  dcterms:title "FOI-O NZ event type vocabulary" .

foio-event:RequestObserved a skos:Concept ; skos:prefLabel "Request observed" ; skos:inScheme foio-event:scheme .
foio-event:MessageObserved a skos:Concept ; skos:prefLabel "Message observed" ; skos:inScheme foio-event:scheme .
foio-event:StateObserved a skos:Concept ; skos:prefLabel "State observed" ; skos:inScheme foio-event:scheme .
foio-event:DeadlineCalculated a skos:Concept ; skos:prefLabel "Deadline calculated" ; skos:inScheme foio-event:scheme .
foio-event:ExtensionNotified a skos:Concept ; skos:prefLabel "Extension notified" ; skos:inScheme foio-event:scheme .
foio-event:TransferNotified a skos:Concept ; skos:prefLabel "Transfer notified" ; skos:inScheme foio-event:scheme .
foio-event:ClarificationRequested a skos:Concept ; skos:prefLabel "Clarification requested" ; skos:inScheme foio-event:scheme .
foio-event:ChargeNoticeSent a skos:Concept ; skos:prefLabel "Charge notice sent" ; skos:inScheme foio-event:scheme .
foio-event:SearchPlanDrafted a skos:Concept ; skos:prefLabel "Search plan drafted" ; skos:inScheme foio-event:scheme .
foio-event:LegalIssueFlagged a skos:Concept ; skos:prefLabel "Legal issue flagged" ; skos:inScheme foio-event:scheme .
foio-event:HumanDecisionCertified a skos:Concept ; skos:prefLabel "Human decision certified" ; skos:inScheme foio-event:scheme .
foio-event:DecisionCommunicated a skos:Concept ; skos:prefLabel "Decision communicated" ; skos:inScheme foio-event:scheme .
foio-event:ReleaseMade a skos:Concept ; skos:prefLabel "Release made" ; skos:inScheme foio-event:scheme .
foio-event:RefusalCommunicated a skos:Concept ; skos:prefLabel "Refusal communicated" ; skos:inScheme foio-event:scheme .
foio-event:ComplaintObserved a skos:Concept ; skos:prefLabel "Complaint observed" ; skos:inScheme foio-event:scheme .
