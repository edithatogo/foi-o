@prefix foio-agent: <https://w3id.org/foio-nz/agent-boundary/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

foio-agent:scheme a skos:ConceptScheme ;
  dcterms:title "FOI-O NZ agent boundary vocabulary" .

foio-agent:safe_process_support a skos:Concept ;
  skos:prefLabel "safe process support" ;
  skos:definition "Low-risk agent work such as metadata extraction, validation, drafting, and reporting support." ;
  skos:inScheme foio-agent:scheme .

foio-agent:human_certification_required a skos:Concept ;
  skos:prefLabel "human certification required" ;
  skos:definition "Preparatory agent work that touches legal or administrative decisions and requires human approval." ;
  skos:inScheme foio-agent:scheme .

foio-agent:prohibited_autonomous_action a skos:Concept ;
  skos:prefLabel "prohibited autonomous action" ;
  skos:definition "An action an agent must not perform autonomously, such as final release/refusal/redaction approval." ;
  skos:inScheme foio-agent:scheme .
