@prefix foio: <https://w3id.org/foio-nz/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/foio-nz/ontology>
  a owl:Ontology ;
  dcterms:title "FOI-O NZ seed ontology" ;
  dcterms:description "A New Zealand-first process ontology for Official Information Act administration and agent-facing workflow support." ;
  owl:versionInfo "0.1.0" .

foio:AccessRequest a owl:Class ;
  rdfs:label "Access request" ;
  rdfs:comment "A request for official information under, or potentially under, an access-to-information regime." .

foio:OIARequest a owl:Class ;
  rdfs:subClassOf foio:AccessRequest ;
  rdfs:label "OIA request" .

foio:ProcessEvent a owl:Class ;
  rdfs:subClassOf prov:Activity ;
  rdfs:label "Process event" ;
  rdfs:comment "An event in the observed, inferred, or certified lifecycle of an access request." .

foio:DecisionLikeEvent a owl:Class ;
  rdfs:subClassOf foio:ProcessEvent ;
  rdfs:label "Decision-like event" ;
  rdfs:comment "An event that may have legal-administrative effect and requires human certification if final." .

foio:HumanCertification a owl:Class ;
  rdfs:subClassOf prov:Activity ;
  rdfs:label "Human certification" .

foio:AgentAction a owl:Class ;
  rdfs:subClassOf prov:Activity ;
  rdfs:label "Agent action" ;
  rdfs:comment "A bounded AI/software action over FOI-O NZ data." .

foio:Evidence a owl:Class ;
  rdfs:subClassOf prov:Entity ;
  rdfs:label "Evidence" ;
  rdfs:comment "A source artefact, archive reference, statute, guidance document, system log, or annotation used to support an event or assertion." .

foio:SourceRecord a owl:Class ;
  rdfs:subClassOf foio:Evidence ;
  rdfs:label "Source record" .

foio:Attachment a owl:Class ;
  rdfs:subClassOf prov:Entity ;
  rdfs:label "Attachment" .

foio:LegalReference a owl:Class ;
  rdfs:label "Legal reference" .

foio:ReportingMetric a owl:Class ;
  rdfs:label "Reporting metric" .

foio:ReviewTask a owl:Class ;
  rdfs:subClassOf prov:Activity ;
  rdfs:label "Review task" ;
  rdfs:comment "A human-review task derived from candidate signals, risks, or certification-boundary requirements." .

foio:RiskAssessment a owl:Class ;
  rdfs:subClassOf prov:Entity ;
  rdfs:label "Risk assessment" .

foio:RedactionCandidate a owl:Class ;
  rdfs:subClassOf prov:Entity ;
  rdfs:label "Redaction candidate" ;
  rdfs:comment "A candidate sensitive span or review signal, not a redaction decision." .

foio:Chunk a owl:Class ;
  rdfs:subClassOf prov:Entity ;
  rdfs:label "Text chunk" .

foio:DatasetPublication a owl:Class ;
  rdfs:subClassOf dcat:Dataset ;
  rdfs:label "Dataset publication" ;
  rdfs:comment "A publication package or dataset metadata record for FOI-O NZ derived artefacts." .

foio:DisclosureLog a owl:Class ;
  rdfs:subClassOf dcat:Catalog ;
  rdfs:label "Disclosure log" .

foio:ProviderRun a owl:Class ;
  rdfs:subClassOf prov:Activity ;
  rdfs:label "Provider run" ;
  rdfs:comment "A bounded model, embedding, or extraction provider run with provenance and safety metadata." .

foio:LegalSourceVersion a owl:Class ;
  rdfs:subClassOf prov:Entity ;
  rdfs:label "Legal source version" ;
  rdfs:comment "A versioned statutory, guidance, or policy source used for process rules or evidence." .

foio:PermissionPolicy a owl:Class ;
  rdfs:subClassOf odrl:Policy ;
  rdfs:label "Permission policy" ;
  rdfs:comment "A rights, reuse, access, prohibition, or duty policy associated with a publication artefact." .

foio:normalisedState a owl:ObjectProperty ;
  rdfs:domain foio:AccessRequest ;
  rdfs:range skos:Concept ;
  rdfs:label "normalised state" .

foio:sourceState a owl:DatatypeProperty ;
  rdfs:domain foio:AccessRequest ;
  rdfs:range xsd:string ;
  rdfs:label "source state" ;
  rdfs:comment "The source state exactly as observed in FYI/Alaveteli or another source system." .

foio:sourceSystem a owl:DatatypeProperty ;
  rdfs:range xsd:string ;
  rdfs:label "source system" .

foio:sourceUrl a owl:DatatypeProperty ;
  rdfs:range xsd:anyURI ;
  rdfs:label "source URL" .

foio:contentSha256 a owl:DatatypeProperty ;
  rdfs:range xsd:string ;
  rdfs:label "content SHA-256" .

foio:assertionStatus a owl:ObjectProperty ;
  rdfs:domain foio:ProcessEvent ;
  rdfs:range skos:Concept ;
  rdfs:label "assertion status" .

foio:requiresHumanCertification a owl:DatatypeProperty ;
  rdfs:domain foio:ProcessEvent ;
  rdfs:range xsd:boolean ;
  rdfs:label "requires human certification" .

foio:humanReviewRequired a owl:DatatypeProperty ;
  rdfs:range xsd:boolean ;
  rdfs:label "human review required" .

foio:legalEffect a owl:DatatypeProperty ;
  rdfs:range xsd:string ;
  rdfs:label "legal effect" .

foio:machineCertificationAllowed a owl:DatatypeProperty ;
  rdfs:range xsd:boolean ;
  rdfs:label "machine certification allowed" ;
  rdfs:comment "Must remain false for bounded agent/model outputs." .

foio:generatedOutputIncluded a owl:DatatypeProperty ;
  rdfs:range xsd:boolean ;
  rdfs:label "generated output included" .

foio:hasHumanCertification a owl:ObjectProperty ;
  rdfs:domain foio:DecisionLikeEvent ;
  rdfs:range foio:HumanCertification ;
  rdfs:label "has human certification" .

foio:hasEvidence a owl:ObjectProperty ;
  rdfs:domain foio:ProcessEvent ;
  rdfs:range foio:Evidence ;
  rdfs:label "has evidence" .

foio:hasLegalReference a owl:ObjectProperty ;
  rdfs:range foio:LegalReference ;
  rdfs:label "has legal reference" .

foio:hasDistribution a owl:ObjectProperty ;
  rdfs:domain foio:DatasetPublication ;
  rdfs:range dcat:Distribution ;
  rdfs:label "has distribution" .

foio:hasPolicy a owl:ObjectProperty ;
  rdfs:range foio:PermissionPolicy ;
  rdfs:label "has policy" .

foio:publicationCaveat a owl:DatatypeProperty ;
  rdfs:domain foio:DatasetPublication ;
  rdfs:range xsd:string ;
  rdfs:label "publication caveat" .

foio:sourceVersionId a owl:DatatypeProperty ;
  rdfs:domain foio:LegalSourceVersion ;
  rdfs:range xsd:string ;
  rdfs:label "source version identifier" .

foio:machineGenerated a owl:DatatypeProperty ;
  rdfs:domain foio:ProcessEvent ;
  rdfs:range xsd:boolean ;
  rdfs:label "machine generated" .

foio:confidence a owl:DatatypeProperty ;
  rdfs:domain foio:ProcessEvent ;
  rdfs:range xsd:decimal ;
  rdfs:label "confidence" .

foio:Agency a owl:Class ;
  rdfs:subClassOf prov:Agent ;
  rdfs:label "Agency" .

foio:hasAuthority a owl:ObjectProperty ;
  rdfs:domain foio:AccessRequest ;
  rdfs:range foio:Agency ;
  rdfs:label "has authority" .

foio:lifecycleState a owl:DatatypeProperty ;
  rdfs:domain foio:AccessRequest ;
  rdfs:range xsd:string ;
  rdfs:label "lifecycle state literal" .

foio:firstSentAt a owl:DatatypeProperty ;
  rdfs:domain foio:AccessRequest ;
  rdfs:range xsd:dateTime ;
  rdfs:label "first sent at" .

foio:eventType a owl:DatatypeProperty ;
  rdfs:domain foio:ProcessEvent ;
  rdfs:range xsd:string ;
  rdfs:label "event type" .

foio:lifecycleStateAfter a owl:DatatypeProperty ;
  rdfs:domain foio:ProcessEvent ;
  rdfs:range xsd:string ;
  rdfs:label "lifecycle state after" .

foio:aboutRequest a owl:ObjectProperty ;
  rdfs:domain foio:ProcessEvent ;
  rdfs:range foio:AccessRequest ;
  rdfs:label "about request" .
