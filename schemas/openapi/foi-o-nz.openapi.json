      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "schemas/json/agent-action.schema.json"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Policy decision"
          }
        },
        "summary": "Evaluate whether a proposed agent action stays within policy.",
        "x-agent-boundary": "guardrail-enforcement",
        "x-legal-effect": "none",
        "x-machine-certification-allowed": false,
        "x-prohibited-follow-on-actions": [
          "certify_release",
          "certify_refusal",
          "approve_redaction",
          "approve_charge",
          "certify_transfer",
          "certify_extension",
          "certify_complaint_or_review_outcome"
