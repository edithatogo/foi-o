  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "set_id", "status", "authorization", "codebook", "context_manifest", "analyst", "request_ids", "record_count", "record_hash_algorithm", "entries", "local_only", "empirical_result_approved", "human_reviewed", "gold_eligible", "prohibited_actions"],
  "properties": {"schema_version": {"const": "foi-o.bounded-pilot-analysis-set.v0.2.0"}, "set_id": {"enum": ["bounded-pilot-a-first-pass", "bounded-pilot-b-first-pass"]}, "status": {"const": "locked_complete_first_pass"}, "authorization": {"$ref": "#/$defs/pin"}, "codebook": {"$ref": "#/$defs/pin"}, "context_manifest": {"$ref": "#/$defs/pin"}, "analyst": {"type": "object"}, "request_ids": {"const": ["11872", "35076"]}, "record_count": {"const": 2}, "record_hash_algorithm": {"const": "sha256_canonical_json_utf8_sort_keys_compact_v1"}, "entries": {"type": "array", "prefixItems": [{"$ref": "#/$defs/entry"}, {"$ref": "#/$defs/entry"}], "items": false, "minItems": 2, "maxItems": 2}, "local_only": {"const": true}, "empirical_result_approved": {"const": false}, "human_reviewed": {"const": false}, "gold_eligible": {"const": false}, "prohibited_actions": {"const": ["empirical_result_approval", "population_inference", "archive_wide_claims", "human_reviewed_claims", "gold_promotion", "legal_certification", "redistribution", "publication", "training", "fine_tuning", "release", "dataset_publication", "paper_updates", "arxiv_submission"]}}
