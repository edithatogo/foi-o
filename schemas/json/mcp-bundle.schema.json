{
  "$id": "https://example.org/schemas/foi-o-nz/mcp-bundle.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "global_boundaries": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "name": {
      "type": "string"
    },
    "model_scope": {
      "const": "global_core_with_versioned_jurisdiction_profiles"
    },
    "origin": {
      "type": "string"
    },
    "jurisdiction_policy": {
      "additionalProperties": false,
      "properties": {
        "explicit_profile_required": {"const": true},
        "cross_jurisdiction_fallback_allowed": {"const": false},
        "unpromoted_profile_outputs": {"const": "candidate_only"},
        "current_iterations": {
          "items": {"type": "string"},
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        }
      },
      "required": [
        "explicit_profile_required",
        "cross_jurisdiction_fallback_allowed",
        "unpromoted_profile_outputs",
        "current_iterations"
      ],
      "type": "object"
    },
    "prompts": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "resources": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "schema_version": {
      "const": "foi-o-nz.mcp-bundle.v0.1.0"
    },
    "tools": {
      "items": {
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "name",
    "model_scope",
    "origin",
    "jurisdiction_policy",
    "resources",
    "prompts",
    "tools",
    "global_boundaries"
  ],
  "title": "FOI-O Global MCP Planning Bundle",
  "type": "object"
}
