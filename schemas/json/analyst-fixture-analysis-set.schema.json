{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:foi-o:schema:analyst-fixture-analysis-set:0.1.0",
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "pin": {"type": "object", "additionalProperties": false, "required": ["path", "sha256"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha256"}}},
    "runtime": {"type": "object", "additionalProperties": false, "required": ["provider", "model", "prompt_sha256", "session_id"], "properties": {"provider": {"type": "string", "minLength": 1}, "model": {"type": "string", "minLength": 1}, "prompt_sha256": {"$ref": "#/$defs/sha256"}, "session_id": {"type": "string", "minLength": 1}}},
    "analyst": {"type": "object", "additionalProperties": false, "required": ["actor_id", "actor_class", "role", "runtime"], "properties": {"actor_id": {"enum": ["agent:analyst-fixture-a", "agent:analyst-fixture-b"]}, "actor_class": {"const": "automated_agent"}, "role": {"const": "analyst"}, "runtime": {"$ref": "#/$defs/runtime"}}},
    "span": {"type": "object", "additionalProperties": false, "required": ["start", "end", "coordinate_system"], "properties": {"start": {"type": "integer", "minimum": 0}, "end": {"type": "integer", "minimum": 1}, "coordinate_system": {"const": "utf8_character_half_open"}}},
    "record": {"type": "object", "additionalProperties": false, "required": ["schema_version", "record_id", "status", "analyst", "unit_sha256", "codebook_revision", "label", "span", "uncertainty", "abstention", "abstention_reason", "notes", "independence", "created_at", "locked_at", "empirical_evidence", "human_reviewed", "gold_eligible"], "properties": {"schema_version": {"const": "foi-o.locked-analyst-record.v0.1.0"}, "record_id": {"type": "string", "minLength": 1}, "status": {"const": "locked_agent_analysis"}, "analyst": {"$ref": "#/$defs/analyst"}, "unit_sha256": {"$ref": "#/$defs/sha256"}, "codebook_revision": {"type": "string", "pattern": "^[a-f0-9]{40}$"}, "label": {"type": ["string", "null"]}, "span": {"oneOf": [{"$ref": "#/$defs/span"}, {"type": "null"}]}, "uncertainty": {"type": "number", "minimum": 0, "maximum": 1}, "abstention": {"type": "boolean"}, "abstention_reason": {"enum": [null, "missing_evidence", "insufficient_evidence", "out_of_scope", "other"]}, "notes": {"type": "string"}, "independence": {"type": "object", "additionalProperties": false, "required": ["blinded_to_peer_outputs", "blinded_to_candidate", "context_sha256"], "properties": {"blinded_to_peer_outputs": {"const": true}, "blinded_to_candidate": {"const": true}, "context_sha256": {"$ref": "#/$defs/sha256"}}}, "created_at": {"type": "string", "format": "date-time"}, "locked_at": {"type": "string", "format": "date-time"}, "empirical_evidence": {"const": false}, "human_reviewed": {"const": false}, "gold_eligible": {"const": false}}, "allOf": [{"if": {"properties": {"abstention": {"const": true}}}, "then": {"properties": {"label": {"const": null}, "span": {"const": null}, "abstention_reason": {"type": "string"}}}, "else": {"properties": {"label": {"type": "string", "minLength": 1}, "abstention_reason": {"const": null}}}}]},
    "entry": {"type": "object", "additionalProperties": false, "required": ["unit_id", "record_sha256", "record"], "properties": {"unit_id": {"pattern": "^(pm-[0-9]{2}|tl-[0-9]{2})$"}, "record_sha256": {"$ref": "#/$defs/sha256"}, "record": {"$ref": "#/$defs/record"}}}
  },
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "set_id", "status", "authorization", "codebook", "context_presentation", "analyst", "unit_count", "ordered_unit_commitment_sha256", "record_hash_algorithm", "entries", "local_only", "empirical_evidence", "human_reviewed", "gold_eligible", "release_qualifying", "publication_eligible", "prohibited_actions"],
  "properties": {"schema_version": {"const": "foi-o.analyst-fixture-analysis-set.v0.1.0"}, "set_id": {"enum": ["local-fixture-analysis-a", "local-fixture-analysis-b"]}, "status": {"const": "locked_agent_analysis_set"}, "authorization": {"$ref": "#/$defs/pin"}, "codebook": {"$ref": "#/$defs/pin"}, "context_presentation": {"$ref": "#/$defs/pin"}, "analyst": {"$ref": "#/$defs/analyst"}, "unit_count": {"const": 11}, "ordered_unit_commitment_sha256": {"$ref": "#/$defs/sha256"}, "record_hash_algorithm": {"const": "sha256_canonical_json_utf8_sort_keys_compact_v1"}, "entries": {"type": "array", "minItems": 11, "maxItems": 11, "items": {"$ref": "#/$defs/entry"}}, "local_only": {"const": true}, "empirical_evidence": {"const": false}, "human_reviewed": {"const": false}, "gold_eligible": {"const": false}, "release_qualifying": {"const": false}, "publication_eligible": {"const": false}, "prohibited_actions": {"const": ["redistribution", "publication", "training", "fine_tuning", "release", "dataset_publication", "gold_promotion", "legal_certification", "paper_update", "human_reviewed_claims", "empirical_evidence_claims"]}}
}
