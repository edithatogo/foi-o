{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/foio-nz/schemas/empirical-taskset-manifest.schema.json",
  "title": "FOI-O NZ empirical task set manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_id",
    "scope",
    "claim_boundary",
    "jurisdiction",
    "task_sets",
    "external_gates",
    "ok"
  ],
  "properties": {
    "schema_version": {
      "const": "foi-o-nz.empirical-taskset-manifest.v0.1.0"
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "const": "NZ-first empirical annotation planning"
    },
    "claim_boundary": {
      "const": "annotation_tasks_not_gold_standard"
    },
    "jurisdiction": {
      "const": "NZ"
    },
    "task_sets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "task_set_id",
          "task_type",
          "planned_count",
          "review_status",
          "source_basis",
          "evidence_fields",
          "competency_questions",
          "claim_boundary"
        ],
        "properties": {
          "task_set_id": {
            "type": "string",
            "minLength": 1
          },
          "task_type": {
            "enum": [
              "state_mapping",
              "timeline_extraction",
              "outcome_classification",
              "legal_issue_flagging",
              "attachment_characterisation"
            ]
          },
          "planned_count": {
            "type": "integer",
            "minimum": 1
          },
          "review_status": {
            "enum": [
              "planned",
              "fixture_only",
              "human_review_pending",
              "human_reviewed"
            ]
          },
          "source_basis": {
            "type": "string",
            "minLength": 1
          },
          "evidence_fields": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "competency_questions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "claim_boundary": {
            "const": "annotation_task_until_human_reviewed"
          }
        }
      }
    },
    "external_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ok": {
      "type": "boolean"
    }
  }
}
