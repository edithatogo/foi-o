{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "urn:foi-o:schema:sampling-configuration:0.1.0",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "configuration_id", "status", "protocol_sha256", "source_population_sha256", "codebook_revision", "random_seed", "probability_sample_size", "enrichment_sample_size", "sample_size_justification", "strata", "inclusion_probability_field", "weight_field", "duplicate_cluster_rule", "exclusion_rule", "split_policy", "bootstrap", "created_at", "approved_by", "approved_at"],
  "properties": {
    "schema_version": {"const": "foi-o.sampling-configuration.v0.1.0"}, "configuration_id": {"type": "string", "minLength": 1}, "status": {"enum": ["candidate_contract_fixture", "approved"]},
    "protocol_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "source_population_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "codebook_revision": {"type": "string", "pattern": "^[a-f0-9]{40}$"}, "random_seed": {"type": "integer", "minimum": 0},
    "probability_sample_size": {"type": "integer", "minimum": 1}, "enrichment_sample_size": {"type": "integer", "minimum": 0}, "sample_size_justification": {"type": "string", "minLength": 20},
    "strata": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "inclusion_probability_field": {"type": "string", "minLength": 1}, "weight_field": {"type": "string", "minLength": 1},
    "duplicate_cluster_rule": {"type": "string", "minLength": 10}, "exclusion_rule": {"type": "string", "minLength": 10},
    "split_policy": {"type": "object", "additionalProperties": false, "required": ["grouped_by", "splits"], "properties": {"grouped_by": {"const": "duplicate_cluster"}, "splits": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["exploration", "train", "validation", "test", "annotation_only"]}}}},
    "bootstrap": {"type": "object", "additionalProperties": false, "required": ["confidence_level", "sides", "resampling_unit", "replicates", "interval_method"], "properties": {"confidence_level": {"const": 0.95}, "sides": {"const": "two_sided"}, "resampling_unit": {"const": "duplicate_cluster"}, "replicates": {"type": "integer", "minimum": 1000}, "interval_method": {"const": "percentile"}}},
    "created_at": {"type": "string", "format": "date-time"}, "approved_by": {"type": ["string", "null"], "pattern": "^human:[A-Za-z0-9._-]+$"}, "approved_at": {"type": ["string", "null"], "format": "date-time"}
  },
  "allOf": [{"if": {"properties": {"status": {"const": "approved"}}}, "then": {"properties": {"approved_by": {"type": "string"}, "approved_at": {"type": "string", "format": "date-time"}}}, "else": {"properties": {"approved_by": {"const": null}, "approved_at": {"const": null}}}}]
}
