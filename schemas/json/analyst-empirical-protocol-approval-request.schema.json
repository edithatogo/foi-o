{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:foi-o:schema:analyst-empirical-protocol-approval-request:0.1.0",
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "pin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "repository_commit"],
      "properties": {
        "path": {"const": "docs/43-v2-analyst-empirical-validation-protocol.md"},
        "sha256": {"const": "1ff93755f9beccb86fe4b3bd67388c68e2202ec62c6ca1848aa01a9157b6d65f"},
        "repository_commit": {"const": "31b2f99ec5d9bacd4ab64974b9c015ce0b44362e"}
      }
    },
    "prohibitions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sample_membership", "analyst_execution", "reconciliation", "empirical_claims", "human_reviewed_claims", "gold_promotion", "legal_certification", "redistribution", "publication", "training", "fine_tuning", "release", "dataset_publication", "paper_updates"],
      "properties": {
        "sample_membership": {"const": false},
        "analyst_execution": {"const": false},
        "reconciliation": {"const": false},
        "empirical_claims": {"const": false},
        "human_reviewed_claims": {"const": false},
        "gold_promotion": {"const": false},
        "legal_certification": {"const": false},
        "redistribution": {"const": false},
        "publication": {"const": false},
        "training": {"const": false},
        "fine_tuning": {"const": false},
        "release": {"const": false},
        "dataset_publication": {"const": false},
        "paper_updates": {"const": false}
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "request_id", "status", "recorded_at", "protocol", "requested_scope", "exact_approval_required", "human_approval_present", "protocol_approved", "sample_membership_approved", "execution_allowed", "empirical_evidence", "human_reviewed", "gold_eligible", "prohibited_actions"],
  "properties": {
    "schema_version": {"const": "foi-o.analyst-empirical-protocol-approval-request.v0.1.0"},
    "request_id": {"const": "foi-o-v2-analyst-empirical-protocol-v0.2"},
    "status": {"const": "pending_exact_human_approval"},
    "recorded_at": {"type": "string", "format": "date-time"},
    "protocol": {"$ref": "#/$defs/pin"},
    "requested_scope": {"const": "approve_v0.2_analyst_protocol_design_only"},
    "exact_approval_required": {"const": "I, edithatogo, approve analyst empirical-validation protocol SHA-256 1ff93755f9beccb86fe4b3bd67388c68e2202ec62c6ca1848aa01a9157b6d65f as committed in 31b2f99ec5d9bacd4ab64974b9c015ce0b44362e for protocol design only. This approval permits automated agents to fill two independent analyst roles and one distinct reconciler role under a separately committed exact execution authorization. It does not authorize sample membership. It does not authorize analyst execution, reconciliation, empirical claims, human-reviewed claims, gold promotion, legal certification, redistribution, publication, training, fine-tuning, release, dataset publication, or paper updates."},
    "human_approval_present": {"const": false},
    "protocol_approved": {"const": false},
    "sample_membership_approved": {"const": false},
    "execution_allowed": {"const": false},
    "empirical_evidence": {"const": false},
    "human_reviewed": {"const": false},
    "gold_eligible": {"const": false},
    "prohibited_actions": {"$ref": "#/$defs/prohibitions"}
  }
}
