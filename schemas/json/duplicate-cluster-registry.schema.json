{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:foi-o:schema:duplicate-cluster-registry:0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "registry_id", "status", "empirical_evidence", "population_manifest_ref", "population_manifest_sha256", "algorithm", "created_at", "frozen_at", "clusters"],
  "properties": {
    "schema_version": {"const": "foi-o.duplicate-cluster-registry.v0.1.0"},
    "registry_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["candidate_contract_fixture", "frozen"]},
    "empirical_evidence": {"type": "boolean"},
    "population_manifest_ref": {"type": "string", "minLength": 1},
    "population_manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "algorithm": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "version", "threshold"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "threshold": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "created_at": {"type": "string", "format": "date-time"},
    "frozen_at": {"type": ["string", "null"], "format": "date-time"},
    "clusters": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["cluster_id", "member_unit_sha256", "split"],
        "properties": {
          "cluster_id": {"type": "string", "minLength": 1},
          "member_unit_sha256": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-f0-9]{64}$"}},
          "split": {"enum": ["exploration", "train", "validation", "test", "annotation_only"]}
        }
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "frozen"}}},
      "then": {"properties": {"empirical_evidence": {"const": true}, "frozen_at": {"type": "string", "format": "date-time"}}},
      "else": {"properties": {"empirical_evidence": {"const": false}, "frozen_at": {"const": null}}}
    }
  ]
}
