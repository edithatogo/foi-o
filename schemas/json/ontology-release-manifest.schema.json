{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:foi-o:schema:ontology-release-manifest:0.1.0",
  "title": "FOI-O ontology family release manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_version", "release_id", "created_at", "core", "profiles"],
  "properties": {
    "manifest_version": {"const": "0.1.0"},
    "release_id": {"type": "string", "pattern": "^foi-o-release/[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "created_at": {"type": "string", "format": "date-time"},
    "core": {"$ref": "#/$defs/core"},
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/profile"}
    },
    "migration_catalogue": {"type": "string", "minLength": 1},
    "compatibility_matrix": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "semver": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uri", "sha256"],
      "properties": {
        "uri": {"type": "string", "format": "uri"},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "core": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "artifact"],
      "properties": {
        "id": {"const": "foi-o"},
        "version": {"$ref": "#/$defs/semver"},
        "artifact": {"$ref": "#/$defs/artifact"}
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "jurisdiction", "core_compatibility", "artifact", "status"],
      "properties": {
        "id": {"type": "string", "pattern": "^foi-o-[a-z]{2}(?:-[a-z0-9]+)*$"},
        "version": {"$ref": "#/$defs/semver"},
        "jurisdiction": {"type": "string", "pattern": "^[A-Z]{2}(?:-[A-Z0-9]{1,3})?$"},
        "core_compatibility": {"type": "string", "pattern": "^(?:\\^|~|>=)[0-9]+\\.[0-9]+\\.[0-9]+(?: <[0-9]+\\.[0-9]+\\.[0-9]+)?$"},
        "parent_profile": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "compatibility"],
          "properties": {
            "id": {"type": "string", "pattern": "^foi-o-[a-z]{2}$"},
            "compatibility": {"type": "string", "minLength": 1}
          }
        },
        "artifact": {"$ref": "#/$defs/artifact"},
        "status": {"enum": ["draft", "pilot", "validated", "stable", "deprecated"]}
      },
      "allOf": [
        {
          "if": {"properties": {"jurisdiction": {"pattern": "^[A-Z]{2}-"}}, "required": ["jurisdiction"]},
          "then": {"required": ["parent_profile"]}
        }
      ]
    }
  }
}
