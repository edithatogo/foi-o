{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/foio/schema/oia-event-time-fixture-set.json",
  "title": "FOI-O OIA event-time candidate fixture set",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "parameterSet",
    "independence",
    "humanReview",
    "sources",
    "cases"
  ],
  "properties": {
    "schemaVersion": {"const": "foi-o.oia-event-time-fixtures.v0.1.0"},
    "status": {"const": "candidate"},
    "parameterSet": {"const": "0.1.0"},
    "independence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authoringFixture", "authoringFixtureSha256", "method"],
      "properties": {
        "authoringFixture": {"const": "tests/fixtures/oia_rules/oia-clock-fixtures.json"},
        "authoringFixtureSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "method": {"type": "string", "minLength": 1}
      }
    },
    "humanReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "promotionAllowed", "requiredAction"],
      "properties": {
        "status": {"const": "pending"},
        "promotionAllowed": {"const": false},
        "requiredAction": {"type": "string", "minLength": 1}
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sourceId", "title", "url", "retrievedAt", "status"],
        "properties": {
          "sourceId": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "url": {"type": "string", "format": "uri"},
          "retrievedAt": {"type": "string", "format": "date"},
          "status": {"enum": ["official_current", "official_snapshot"]}
        }
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/case"}
    }
  },
  "$defs": {
    "valueObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["valueState"],
      "properties": {
        "value": {},
        "valueState": {"enum": ["known", "unknown", "not_provided", "verified_stale"]},
        "epistemicStatus": {"type": ["string", "null"]},
        "warnings": {"type": "array", "items": {"type": "string"}}
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "caseId",
        "description",
        "eventTime",
        "decisionId",
        "sourceRefs",
        "inputs",
        "expected"
      ],
      "properties": {
        "caseId": {"type": "string", "pattern": "^nz-oia/candidate-fixture\\."},
        "description": {"type": "string", "minLength": 1},
        "eventTime": {"type": "string", "format": "date"},
        "decisionId": {"type": "string", "pattern": "^nz-oia/decision\\."},
        "sourceRefs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "inputs": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {"$ref": "#/$defs/valueObject"}
        },
        "expected": {"$ref": "#/$defs/valueObject"}
      }
    }
  }
}
