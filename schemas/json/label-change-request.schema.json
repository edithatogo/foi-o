{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:foi-o:schema:empirical:label-change-request:0.1.0",
  "title": "FOI-O label change request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "change_id",
    "code_id",
    "change_type",
    "proposed_by",
    "created_at",
    "rationale",
    "evidence_refs",
    "impact_assessment",
    "migration_plan",
    "review_status"
  ],
  "properties": {
    "change_id": {
      "type": "string",
      "minLength": 1
    },
    "code_id": {
      "type": "string",
      "minLength": 1
    },
    "change_type": {
      "enum": [
        "add",
        "clarify",
        "split",
        "merge",
        "deprecate",
        "correct"
      ]
    },
    "proposed_by": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "enum": [
            "human",
            "software_candidate"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "rationale": {
      "type": "string",
      "minLength": 20
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "impact_assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "affected_versions",
        "affected_assertions",
        "backward_compatible"
      ],
      "properties": {
        "affected_versions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "affected_assertions": {
          "type": "integer",
          "minimum": 0
        },
        "backward_compatible": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "migration_plan": {
      "type": "string",
      "minLength": 10
    },
    "review_status": {
      "enum": [
        "proposed",
        "under_review",
        "approved",
        "rejected",
        "implemented"
      ]
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "reviewer_id",
          "decision",
          "reviewed_at"
        ],
        "properties": {
          "reviewer_id": {
            "type": "string",
            "minLength": 1
          },
          "decision": {
            "enum": [
              "approve",
              "reject",
              "request_changes"
            ]
          },
          "reviewed_at": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "effective_version": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "review_status": {
            "enum": [
              "approved",
              "implemented"
            ]
          }
        }
      },
      "then": {
        "required": [
          "approvals",
          "effective_version"
        ],
        "properties": {
          "approvals": {
            "minItems": 1,
            "contains": {
              "type": "object",
              "properties": {
                "decision": {
                  "const": "approve"
                }
              },
              "required": [
                "decision"
              ]
            }
          }
        }
      }
    }
  ]
}
