{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foi-o.nz/schemas/reporting-checklist-source.schema.json",
  "title": "FOI-O NZ reporting checklist source snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "checklist_id",
    "title",
    "source_url",
    "retrieved_at",
    "publisher",
    "applicability",
    "items"
  ],
  "properties": {
    "schema_version": {
      "const": "foi-o-nz.reporting-checklist-source.v0.1.0"
    },
    "checklist_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "source_url": {
      "type": "string",
      "format": "uri"
    },
    "retrieved_at": {
      "type": "string",
      "format": "date-time"
    },
    "publisher": {
      "type": "string",
      "minLength": 1
    },
    "applicability": {
      "enum": [
        "required",
        "optional",
        "not_applicable",
        "external_gate"
      ]
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "item_id",
          "text",
          "applicability"
        ],
        "properties": {
          "item_id": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "applicability": {
            "enum": [
              "required",
              "optional",
              "not_applicable",
              "external_gate"
            ]
          }
        }
      }
    }
  }
}
