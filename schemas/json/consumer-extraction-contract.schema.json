{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:foi-o:schema:consumer-extraction-contract:0.1.0",
  "title": "FOI-O offline consumer extraction contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "consumer_id",
    "consumer_surface",
    "contract_id",
    "accepted_versions",
    "rejected_versions",
    "required_capability_ids",
    "read_only",
    "candidate_only",
    "machine_certification_allowed",
    "verification_scope",
    "upstream_verified"
  ],
  "properties": {
    "schema_version": {"const": "foi-o.consumer-extraction-contract.v0.1.0"},
    "consumer_id": {"enum": ["foi-o-nz", "fyi-archive", "nlp-policy-nz", "foi-o-read-only-mcp"]},
    "consumer_surface": {"enum": ["producer_validation", "archive_derived_layer", "candidate_extraction", "read_only_mcp"]},
    "contract_id": {"const": "foi-o.extraction-contract"},
    "accepted_versions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"}
    },
    "rejected_versions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["version", "reason"],
        "properties": {
          "version": {"type": "string", "minLength": 1},
          "reason": {"enum": ["invalid_version_rejected", "unknown_major_rejected", "unsupported_revision_rejected"]}
        }
      }
    },
    "required_capability_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "read_only": {"type": "boolean"},
    "candidate_only": {"const": true},
    "machine_certification_allowed": {"const": false},
    "verification_scope": {"const": "repo_local_offline"},
    "upstream_verified": {"const": false}
  },
  "allOf": [
    {
      "if": {"properties": {"consumer_surface": {"const": "read_only_mcp"}}, "required": ["consumer_surface"]},
      "then": {"properties": {"read_only": {"const": true}}}
    }
  ]
}
