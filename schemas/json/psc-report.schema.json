{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/foio-nz/schema/psc-report/0.1.0",
  "title": "FOI-O NZ PSC-style aggregate report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_schema_version",
    "source_profile",
    "source_url",
    "input",
    "input_event_count",
    "metric_count",
    "metrics",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "foi-o-nz.psc-report.v0.1.0"
    },
    "profile_schema_version": {
      "type": "string"
    },
    "source_profile": {
      "type": "string"
    },
    "source_url": {
      "type": "string",
      "format": "uri"
    },
    "input": {
      "type": "string"
    },
    "output": {
      "type": "string"
    },
    "input_event_count": {
      "type": "integer",
      "minimum": 0
    },
    "metric_count": {
      "type": "integer",
      "minimum": 0
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "metric_id",
          "name",
          "derivability",
          "status",
          "value",
          "public_indicator_count",
          "event_count",
          "request_count",
          "event_dependencies",
          "matched_event_types",
          "public_data_limitations",
          "exclusions",
          "official_reporting_caveat",
          "warnings"
        ],
        "properties": {
          "metric_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "derivability": {
            "type": "string",
            "enum": [
              "public_fyi_derivable",
              "partially_derivable",
              "agency_internal_required",
              "not_derivable"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "derived_public_indicator",
              "partial_indicator",
              "agency_internal_required",
              "not_derivable"
            ]
          },
          "value": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "public_indicator_count": {
            "type": "integer",
            "minimum": 0
          },
          "event_count": {
            "type": "integer",
            "minimum": 0
          },
          "request_count": {
            "type": "integer",
            "minimum": 0
          },
          "event_dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "matched_event_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "public_data_limitations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "exclusions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "official_reporting_caveat": {
            "type": "string"
          },
          "warnings": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
