{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:foi-o:schema:extraction-contract:0.1.0",
  "title": "FOI-O versioned extraction contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract_id",
    "contract_version",
    "producer_id",
    "consumer_id",
    "ontology_release",
    "schema_ids",
    "codebook",
    "provenance_identifiers",
    "candidate_status_vocabulary",
    "capability_ids",
    "migration_catalogue",
    "artifacts",
    "human_promotion_required"
  ],
  "properties": {
    "schema_version": {"const": "foi-o.extraction-contract.v0.1.0"},
    "contract_id": {"const": "foi-o.extraction-contract"},
    "contract_version": {"const": "0.1.0"},
    "producer_id": {"const": "foi-o-nz"},
    "consumer_id": {"const": "nlp-policy-nz"},
    "ontology_release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest_schema_id", "manifest_schema_artifact_id", "ontology_id", "ontology_version", "artifact_id"],
      "properties": {
        "manifest_schema_id": {"const": "urn:foi-o:schema:ontology-release-manifest:0.1.0"},
        "manifest_schema_artifact_id": {"type": "string", "minLength": 1},
        "ontology_id": {"const": "https://w3id.org/foio-nz/ontology"},
        "ontology_version": {"const": "0.1.0"},
        "artifact_id": {"type": "string", "minLength": 1}
      }
    },
    "schema_ids": {"$ref": "#/$defs/nonEmptyUniqueArray"},
    "codebook": {"$ref": "#/$defs/reference"},
    "provenance_identifiers": {"$ref": "#/$defs/nonEmptyUniqueArray"},
    "candidate_status_vocabulary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "artifact_id", "allowed_statuses", "certified_status_allowed"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "artifact_id": {"type": "string", "minLength": 1},
        "allowed_statuses": {
          "const": ["observed", "inferred", "asserted", "unknown"]
        },
        "certified_status_allowed": {"const": false}
      }
    },
    "capability_ids": {"$ref": "#/$defs/nonEmptyUniqueArray"},
    "migration_catalogue": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "migration_id",
          "from_version",
          "to_contract_version",
          "artifact_id",
          "automatic_scope",
          "human_promotion_required"
        ],
        "properties": {
          "migration_id": {"type": "string", "minLength": 1},
          "from_version": {"type": "string", "minLength": 1},
          "to_contract_version": {"const": "0.1.0"},
          "artifact_id": {"type": "string", "minLength": 1},
          "automatic_scope": {"const": "linkage_only"},
          "human_promotion_required": {"const": true}
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/artifact"}
    },
    "human_promotion_required": {"const": true}
  },
  "$defs": {
    "nonEmptyUniqueArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "artifact_id"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "artifact_id": {"type": "string", "minLength": 1}
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "kind", "path", "version", "identifier", "sha256"],
      "properties": {
        "artifact_id": {"type": "string", "minLength": 1},
        "kind": {"enum": ["ontology", "schema", "codebook", "vocabulary", "migration"]},
        "path": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._/-]+$",
          "not": {"pattern": "(^|/)(main|latest|\\.\\.)(/|$)"}
        },
        "version": {"type": "string", "minLength": 1},
        "identifier": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    }
  }
}
