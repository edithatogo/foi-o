{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:foi-o:schema:empirical:derivability-assessment:0.1.0",
  "title": "FOI-O derivability assessment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "assessment_id",
    "claim_type",
    "subject_ref",
    "status",
    "required_facts",
    "observed_facts",
    "missing_facts",
    "allowed_outputs",
    "prohibited_outputs",
    "assessed_at"
  ],
  "properties": {
    "assessment_id": {
      "type": "string",
      "minLength": 1
    },
    "claim_type": {
      "type": "string",
      "minLength": 1
    },
    "subject_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "status": {
      "enum": [
        "directly_derivable",
        "partially_derivable",
        "requires_attachment_review",
        "requires_agency_internal_record",
        "requires_human_legal_review",
        "not_derivable_from_public_platform"
      ]
    },
    "required_facts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "fact_id",
          "description"
        ],
        "properties": {
          "fact_id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "source_ref_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          }
        }
      }
    },
    "observed_facts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "fact_id",
          "description"
        ],
        "properties": {
          "fact_id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "source_ref_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          }
        }
      }
    },
    "missing_facts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "fact_id",
          "description"
        ],
        "properties": {
          "fact_id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "source_ref_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          }
        }
      }
    },
    "allowed_outputs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prohibited_outputs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "assessed_at": {
      "type": "string",
      "format": "date-time"
    },
    "assessor_id": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "directly_derivable"
          }
        }
      },
      "then": {
        "properties": {
          "missing_facts": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "not_derivable_from_public_platform"
          }
        }
      },
      "then": {
        "properties": {
          "prohibited_outputs": {
            "minItems": 1
          }
        }
      }
    }
  ]
}
