{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/foio-nz/schemas/process-mining-ocel.schema.json",
  "title": "FOI-O NZ process mining OCEL fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scope",
    "claim_boundary",
    "generated_at",
    "object_types",
    "event_types",
    "objects",
    "events",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "const": "foi-o-nz.process-mining-ocel.v0.1.0"
    },
    "scope": {
      "const": "fixture_only"
    },
    "claim_boundary": {
      "const": "not_live_corpus_validation"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "object_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "const": "foi_request"
          }
        }
      }
    },
    "event_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "objects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type",
          "attributes"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "const": "foi_request"
          },
          "attributes": {
            "type": "object"
          }
        }
      }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "activity",
          "timestamp",
          "objects",
          "attributes"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "activity": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "objects": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "attributes": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "assertion_status",
              "lifecycle_state_after",
              "machine_generated",
              "requires_human_certification"
            ],
            "properties": {
              "assertion_status": {
                "type": "string"
              },
              "lifecycle_state_after": {
                "type": "string"
              },
              "machine_generated": {
                "type": "boolean"
              },
              "requires_human_certification": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
