{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:foi-o:schema:nz-source-pack-review-readiness:0.2.0",
  "title": "FOI-O NZ source-pack human review readiness",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "status", "approved_review_packet_sha256", "reviewer",
    "approved_components", "provider_scope_interpretation", "event_time_intervals", "non_legislation_sources",
    "source_pack_ready", "source_pack_promotion_allowed", "blockers"
  ],
  "properties": {
    "schema_version": {"const": "foi-o.nz-source-pack-review-readiness.v0.2.0"},
    "status": {"const": "candidate_inputs_acquired_human_review_pending"},
    "approved_review_packet_sha256": {"$ref": "#/$defs/sha256"},
    "reviewer": {
      "type": "object", "additionalProperties": false,
      "required": ["reviewer_id", "reviewed_at"],
      "properties": {
        "reviewer_id": {"const": "edithatogo"},
        "reviewed_at": {"type": "string", "format": "date-time"}
      }
    },
    "approved_components": {
      "type": "array", "minItems": 2, "maxItems": 2, "uniqueItems": true,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["component", "artifact_path", "artifact_sha256", "decision"],
        "properties": {
          "component": {"enum": ["oia_version_index", "provider_scope_registry"]},
          "artifact_path": {"type": "string", "minLength": 1},
          "artifact_sha256": {"$ref": "#/$defs/sha256"},
          "decision": {"const": "approved"}
        }
      }
    },
    "provider_scope_interpretation": {
      "type": "object", "additionalProperties": false,
      "required": ["existing_registry_approved", "psc_scope_approved", "review_artifact_path", "review_artifact_sha256", "approval_scope"],
      "properties": {
        "existing_registry_approved": {"const": true},
        "psc_scope_approved": {"const": true},
        "review_artifact_path": {"const": "examples/v2/psc-provider-scope-review.approved.json"},
        "review_artifact_sha256": {"$ref": "#/$defs/sha256"},
        "approval_scope": {"type": "string", "minLength": 1}
      }
    },
    "event_time_intervals": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "interval_count", "artifact_path", "artifact_sha256", "human_approved", "review_artifact_path", "review_artifact_sha256", "approval_scope"],
      "properties": {
        "status": {"const": "approved_bounded_legal_review"},
        "interval_count": {"const": 50},
        "artifact_path": {"const": "mappings/nz-oia-applicability-interval-candidates.yaml"},
        "artifact_sha256": {"$ref": "#/$defs/sha256"},
        "human_approved": {"const": true},
        "review_artifact_path": {"const": "examples/v2/nz-oia-applicability-interval-review.approved.json"},
        "review_artifact_sha256": {"$ref": "#/$defs/sha256"},
        "approval_scope": {"type": "string", "minLength": 1}
      }
    },
    "non_legislation_sources": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "artifact_count", "manifest_path", "manifest_sha256", "content_storage", "content_committed", "human_approved", "required_action"],
      "properties": {
        "status": {"const": "candidate_artifacts_acquired_human_review_pending"},
        "artifact_count": {"const": 7},
        "manifest_path": {"const": "examples/v2/nz-nonlegislation-source-manifest.2026-07-16.json"},
        "manifest_sha256": {"$ref": "#/$defs/sha256"},
        "content_storage": {"const": "local_only"},
        "content_committed": {"const": false},
        "human_approved": {"const": false},
        "required_action": {"type": "string", "minLength": 1}
      }
    },
    "source_pack_ready": {"const": false},
    "source_pack_promotion_allowed": {"const": false},
    "blockers": {
      "type": "array", "minItems": 2, "maxItems": 2, "uniqueItems": true,
      "items": {
        "enum": [
          "event_time_human_review_pending", "psc_provider_scope_review_pending",
          "nonleg_source_selection_review_pending", "source_pack_promotion_pending"
        ]
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
