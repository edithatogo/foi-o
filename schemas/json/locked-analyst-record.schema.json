{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:foi-o:schema:locked-analyst-record:0.1.0",
  "$defs": {
    "runtime": {"type": "object", "additionalProperties": false, "required": ["provider", "model", "prompt_sha256", "session_id"], "properties": {"provider": {"type": "string", "minLength": 1}, "model": {"type": "string", "minLength": 1}, "prompt_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "session_id": {"type": "string", "minLength": 1}}},
    "analyst": {"type": "object", "additionalProperties": false, "required": ["actor_id", "actor_class", "role", "runtime"], "properties": {"actor_id": {"type": "string", "pattern": "^agent:analyst-[A-Za-z0-9._-]+$"}, "actor_class": {"const": "automated_agent"}, "role": {"const": "analyst"}, "runtime": {"$ref": "#/$defs/runtime"}}},
    "span": {"type": "object", "additionalProperties": false, "required": ["start", "end", "coordinate_system"], "properties": {"start": {"type": "integer", "minimum": 0}, "end": {"type": "integer", "minimum": 0}, "coordinate_system": {"const": "utf8_character_half_open"}}}
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "record_id", "status", "analyst", "unit_sha256", "codebook_revision", "label", "span", "uncertainty", "abstention", "abstention_reason", "notes", "independence", "created_at", "locked_at", "empirical_evidence", "human_reviewed", "gold_eligible"],
  "properties": {
    "schema_version": {"const": "foi-o.locked-analyst-record.v0.1.0"},
    "record_id": {"type": "string", "minLength": 1},
    "status": {"const": "locked_agent_analysis"},
    "analyst": {"$ref": "#/$defs/analyst"},
    "unit_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "codebook_revision": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "label": {"type": ["string", "null"]},
    "span": {"oneOf": [{"$ref": "#/$defs/span"}, {"type": "null"}]},
    "uncertainty": {"type": "number", "minimum": 0, "maximum": 1},
    "abstention": {"type": "boolean"},
    "abstention_reason": {"type": ["string", "null"], "enum": [null, "missing_evidence", "insufficient_evidence", "out_of_scope", "other"]},
    "notes": {"type": "string"},
    "independence": {"type": "object", "additionalProperties": false, "required": ["blinded_to_peer_outputs", "blinded_to_candidate", "context_sha256"], "properties": {"blinded_to_peer_outputs": {"const": true}, "blinded_to_candidate": {"const": true}, "context_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}},
    "created_at": {"type": "string", "format": "date-time"},
    "locked_at": {"type": "string", "format": "date-time"},
    "empirical_evidence": {"const": false},
    "human_reviewed": {"const": false},
    "gold_eligible": {"const": false}
  },
  "allOf": [
    {"if": {"properties": {"abstention": {"const": true}}}, "then": {"properties": {"label": {"const": null}, "span": {"const": null}, "abstention_reason": {"type": "string"}}}, "else": {"properties": {"label": {"type": "string", "minLength": 1}, "abstention_reason": {"const": null}}}}
  ]
}
