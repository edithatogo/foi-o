{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "urn:foi-o:schema:analyst-redaction-manifest:0.1.0",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "manifest_id", "status", "local_only", "empirical_evidence", "human_reviewed", "gold_eligible", "release_qualifying", "publication_eligible", "forbidden_keys", "canonicalization", "created_at", "locked_at", "entries"],
  "properties": {"schema_version": {"const": "foi-o.analyst-redaction-manifest.v0.1.0"}, "manifest_id": {"type": "string", "minLength": 1}, "status": {"const": "locked"}, "local_only": {"const": true}, "empirical_evidence": {"const": false}, "human_reviewed": {"const": false}, "gold_eligible": {"const": false}, "release_qualifying": {"const": false}, "publication_eligible": {"const": false}, "forbidden_keys": {"const": ["assertion_status", "confidence"]}, "canonicalization": {"type": "object", "additionalProperties": false, "required": ["parse", "ensure_ascii", "sort_keys", "separators", "encoding"], "properties": {"parse": {"const": "json_object"}, "ensure_ascii": {"const": false}, "sort_keys": {"const": true}, "separators": {"const": [",", ":"]}, "encoding": {"const": "utf-8"}}}, "created_at": {"type": "string", "format": "date-time"}, "locked_at": {"type": "string", "format": "date-time"}, "entries": {"type": "array", "minItems": 11, "maxItems": 11, "uniqueItems": true, "items": {"type": "object", "additionalProperties": false, "required": ["unit_id", "unit_sha256", "context_sha256", "removed_keys", "forbidden_keys_absent"], "properties": {"unit_id": {"type": "string", "minLength": 1}, "unit_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "context_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "removed_keys": {"type": "array", "uniqueItems": true, "items": {"enum": ["assertion_status", "confidence"]}}, "forbidden_keys_absent": {"const": true}}}}}
}
