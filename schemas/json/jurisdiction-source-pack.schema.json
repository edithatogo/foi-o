{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:foi-o:schema:empirical:jurisdiction-source-pack:0.1.0",
  "title": "FOI-O jurisdiction source pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pack_id",
    "jurisdiction",
    "version",
    "generated_at",
    "law_at_event_time",
    "normative_source_ids",
    "components",
    "rights_review_status"
  ],
  "properties": {
    "pack_id": {
      "type": "string",
      "minLength": 1
    },
    "jurisdiction": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "law_at_event_time": {
      "const": true
    },
    "normative_source_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "components": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "legislation_versions"
      ],
      "properties": {
        "legislation_versions": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "regulations_and_instruments": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "gazettes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "parliamentary_materials": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "review_findings": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "guidance": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "calendars": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "authority_identity_history": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "calendar_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "authority_identity_registry_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rights_review_status": {
      "enum": [
        "pending",
        "approved",
        "restricted"
      ]
    },
    "rights_approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approved_by",
        "approved_at"
      ],
      "properties": {
        "approved_by": {
          "type": "string",
          "minLength": 1
        },
        "approved_at": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "source_manifest_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "rights_review_status": {
            "const": "approved"
          }
        }
      },
      "then": {
        "required": [
          "rights_approval"
        ]
      }
    }
  ]
}
