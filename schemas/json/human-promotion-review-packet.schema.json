{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:foi-o:schema:human-promotion-review-packet:0.1.0",
  "title": "FOI-O human promotion review packet",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "packet_id", "overall_status", "promotion_allowed", "reviewer", "items", "excluded_evidence"],
  "properties": {
    "schema_version": {"const": "foi-o.human-promotion-review-packet.v0.1.0"},
    "packet_id": {"type": "string", "minLength": 1},
    "overall_status": {"const": "approved"},
    "promotion_allowed": {"const": true},
    "reviewer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewer_id", "reviewed_at"],
      "properties": {
        "reviewer_id": {"type": "string", "minLength": 1},
        "reviewed_at": {"type": "string", "format": "date-time"}
      }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["item_id", "decision_kind", "artifact_path", "artifact_sha256", "decision", "promotion_allowed", "required_review"],
        "properties": {
          "item_id": {"type": "string", "minLength": 1},
          "decision_kind": {"enum": ["fixture_promotion", "legal_mapping_approval", "rights_scope_approval"]},
          "artifact_path": {"type": "string", "minLength": 1},
          "artifact_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "decision": {"const": "approved"},
          "promotion_allowed": {"const": true},
          "required_review": {"type": "string", "minLength": 1}
        }
      }
    },
    "excluded_evidence": {
      "type": "array",
      "prefixItems": [{
        "type": "object",
        "additionalProperties": false,
        "required": ["path_glob", "reason"],
        "properties": {
          "path_glob": {"const": "examples/v2/schema-valid/*.json"},
          "reason": {"const": "contract_fixtures_not_human_approval_evidence"}
        }
      }],
      "items": false,
      "minItems": 1,
      "maxItems": 1
    }
  }
}
