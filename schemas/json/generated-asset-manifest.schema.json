{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foi-o.nz/schemas/generated-asset-manifest.schema.json",
  "title": "FOI-O NZ generated asset manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_id",
    "generated_at",
    "scope",
    "assets"
  ],
  "properties": {
    "schema_version": {
      "const": "foi-o-nz.generated-asset-manifest.v0.1.0"
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "asset_id",
          "asset_type",
          "path",
          "status",
          "title",
          "caption",
          "text_alternative",
          "source_inputs",
          "generation_command",
          "provenance",
          "intended_location"
        ],
        "properties": {
          "asset_id": {
            "type": "string",
            "minLength": 1
          },
          "asset_type": {
            "enum": [
              "diagram_source",
              "static_diagram",
              "graph_data",
              "data",
              "table",
              "plot",
              "manifest"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "committed_source",
              "committed_static",
              "planned",
              "external_gate"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "caption": {
            "type": "string",
            "minLength": 1
          },
          "text_alternative": {
            "type": "string",
            "minLength": 1
          },
          "source_inputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "generation_command": {
            "type": "string",
            "minLength": 1
          },
          "provenance": {
            "type": "string",
            "minLength": 1
          },
          "intended_location": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
