{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:foi-o:schema:governed-reextraction-packet:0.1.0",
  "title": "FOI-O governed re-extraction handoff packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "packet_id", "purpose", "source_request_id",
    "source_manifest_sha256", "source_content_sha256",
    "reviewed_pending_manifest_sha256", "archive_revision", "fyi_cli_revision",
    "pipeline_revision", "verifier_revision", "baseline_schema_version",
    "baseline_sha256", "baseline_verification_sha256", "contract_version",
    "contract_sha256", "model_id", "model_revision", "model_weights_sha256",
    "model_applied_in_baseline", "rights_reviewer", "rights_reviewed_at", "storage",
    "redistribution_allowed", "training_allowed", "fine_tuning_allowed",
    "release_allowed", "dataset_publication_allowed",
    "ready_for_candidate_reextraction",
    "ready_for_empirical_comparison", "comparison_blockers",
    "human_promotion_required", "promotion_allowed",
    "reviewed_gold_label_promotion_allowed", "publication_allowed",
    "source_records_modified"
  ],
  "properties": {
    "schema_version": {"const": "foi-o.governed-reextraction-packet.v0.1.0"},
    "packet_id": {"const": "foio-nz-35076-initial-baseline"},
    "purpose": {"const": "foi-o-candidate-extraction"},
    "source_request_id": {"type": "string", "minLength": 1},
    "source_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "source_content_sha256": {"$ref": "#/$defs/sha256"},
    "reviewed_pending_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "archive_revision": {"$ref": "#/$defs/revision"},
    "fyi_cli_revision": {"$ref": "#/$defs/revision"},
    "pipeline_revision": {"$ref": "#/$defs/revision"},
    "verifier_revision": {"$ref": "#/$defs/revision"},
    "baseline_schema_version": {"const": "nlp-policy-nz.foio-raw-extraction.v0.2.0"},
    "baseline_sha256": {"$ref": "#/$defs/sha256"},
    "baseline_verification_sha256": {"$ref": "#/$defs/sha256"},
    "contract_version": {"const": "0.1.0"},
    "contract_sha256": {"$ref": "#/$defs/sha256"},
    "model_id": {"const": "nlpaueb/legal-bert-base-uncased"},
    "model_revision": {"$ref": "#/$defs/revision"},
    "model_weights_sha256": {"$ref": "#/$defs/sha256"},
    "model_applied_in_baseline": {"const": false},
    "rights_reviewer": {"type": "string", "minLength": 1},
    "rights_reviewed_at": {"type": "string", "format": "date-time"},
    "storage": {"const": "local_only"},
    "redistribution_allowed": {"const": false},
    "training_allowed": {"const": false},
    "fine_tuning_allowed": {"const": false},
    "release_allowed": {"const": false},
    "dataset_publication_allowed": {"const": false},
    "ready_for_candidate_reextraction": {"const": true},
    "ready_for_empirical_comparison": {"const": false},
    "comparison_blockers": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "uniqueItems": true,
      "items": {"enum": ["independent_annotation_pending", "synthetic_fixture_only"]}
    },
    "human_promotion_required": {"const": true},
    "promotion_allowed": {"const": false},
    "reviewed_gold_label_promotion_allowed": {"const": false},
    "publication_allowed": {"const": false},
    "source_records_modified": {"const": false}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "revision": {"type": "string", "pattern": "^[a-f0-9]{40}$"}
  }
}
