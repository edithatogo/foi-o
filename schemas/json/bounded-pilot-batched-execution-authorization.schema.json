{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:foi-o:schema:bounded-pilot-batched-execution-authorization:0.1.0",
  "$defs": {
    "pin": {"type": "object", "additionalProperties": false, "required": ["path", "sha256", "repository_commit"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "repository_commit": {"type": "string", "pattern": "^[a-f0-9]{40}$"}}},
    "stage": {"type": "object", "additionalProperties": false, "required": ["id", "authorized", "failure_action"], "properties": {"id": {"pattern": "^S[2-8]$"}, "authorized": {"const": true}, "failure_action": {"const": "stop_fail_closed"}}}
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "authorization_id", "status", "plan", "approval", "local_roots", "context_contract", "analyst_roles", "reconciler_role", "implementation_contracts", "runtime_handshake_readiness", "ordered_stages", "authorization_effective_after_verification", "context_materialization_authorized", "context_presentation_authorized", "analyst_execution_authorized", "reconciliation_authorized_conditionally", "candidate_manuscript_preparation_authorized", "local_package_validation_authorized", "final_exact_results_and_package_approval_required", "empirical_result_approved", "human_reviewed", "gold_eligible", "population_inference_allowed", "archive_wide_claim_allowed", "redistribution_allowed", "publication_allowed", "release_allowed", "dataset_publication_allowed", "paper_updates_allowed", "arxiv_submission_allowed", "external_action_allowed"],
  "properties": {
    "schema_version": {"const": "foi-o.bounded-pilot-batched-execution-authorization.v0.1.0"},
    "authorization_id": {"const": "bounded-pilot-11872-35076-batched-local-execution-v0.1"},
    "status": {"const": "approved_pending_exact_pre_execution_verification"},
    "plan": {"$ref": "#/$defs/pin"},
    "approval": {"$ref": "#/$defs/pin"},
    "local_roots": {"type": "object"},
    "context_contract": {"type": "object"},
    "analyst_roles": {"type": "object", "additionalProperties": false, "required": ["analyst_a", "analyst_b"], "properties": {"analyst_a": {"type": "object"}, "analyst_b": {"type": "object"}}},
    "reconciler_role": {"type": "object"},
    "implementation_contracts": {"type": "object", "minProperties": 1, "additionalProperties": {"$ref": "#/$defs/pin"}},
    "runtime_handshake_readiness": {"$ref": "#/$defs/pin"},
    "ordered_stages": {"type": "array", "prefixItems": [{"allOf": [{"$ref": "#/$defs/stage"}, {"properties": {"id": {"const": "S2"}}}]}, {"allOf": [{"$ref": "#/$defs/stage"}, {"properties": {"id": {"const": "S3"}}}]}, {"allOf": [{"$ref": "#/$defs/stage"}, {"properties": {"id": {"const": "S4"}}}]}, {"allOf": [{"$ref": "#/$defs/stage"}, {"properties": {"id": {"const": "S5"}}}]}, {"allOf": [{"$ref": "#/$defs/stage"}, {"properties": {"id": {"const": "S6"}}}]}, {"allOf": [{"$ref": "#/$defs/stage"}, {"properties": {"id": {"const": "S7"}}}]}, {"allOf": [{"$ref": "#/$defs/stage"}, {"properties": {"id": {"const": "S8"}}}]}], "items": false, "minItems": 7, "maxItems": 7},
    "authorization_effective_after_verification": {"const": true},
    "context_materialization_authorized": {"const": true},
    "context_presentation_authorized": {"const": true},
    "analyst_execution_authorized": {"const": true},
    "reconciliation_authorized_conditionally": {"const": true},
    "candidate_manuscript_preparation_authorized": {"const": true},
    "local_package_validation_authorized": {"const": true},
    "final_exact_results_and_package_approval_required": {"const": true},
    "empirical_result_approved": {"const": false},
    "human_reviewed": {"const": false},
    "gold_eligible": {"const": false},
    "population_inference_allowed": {"const": false},
    "archive_wide_claim_allowed": {"const": false},
    "redistribution_allowed": {"const": false},
    "publication_allowed": {"const": false},
    "release_allowed": {"const": false},
    "dataset_publication_allowed": {"const": false},
    "paper_updates_allowed": {"const": false},
    "arxiv_submission_allowed": {"const": false},
    "external_action_allowed": {"const": false}
  }
}
