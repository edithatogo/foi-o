{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "urn:foi-o:schema:fixture-context-presentation:0.1.0",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "status", "canonicalization", "unit_count", "contexts", "execution_allowed"],
  "properties": {
    "schema_version": {"const": "foi-o.fixture-context-presentation.v0.1.0"}, "status": {"const": "prepared_not_presented"}, "canonicalization": {"const": "utf8_json_sort_keys_compact_remove_assertion_status_confidence_v1"}, "unit_count": {"const": 11}, "execution_allowed": {"const": false},
    "contexts": {"type": "array", "minItems": 11, "maxItems": 11, "items": {"type": "object", "additionalProperties": false, "required": ["unit_id", "unit_sha256", "context_sha256", "source_path", "source_span", "removed_keys", "presented_context"], "properties": {"unit_id": {"type": "string", "pattern": "^(pm-[0-9]{2}|tl-[0-9]{2})$"}, "unit_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "context_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "source_path": {"enum": ["examples/process-mining-events.fixture.jsonl", "examples/event-timeline.small.json"]}, "source_span": {"type": "object", "additionalProperties": false, "required": ["start", "end"], "properties": {"start": {"type": "integer", "minimum": 0}, "end": {"type": "integer", "minimum": 1}}}, "removed_keys": {"type": "array", "uniqueItems": true, "items": {"enum": ["assertion_status", "confidence"]}}, "presented_context": {"type": "object"}}}}
  }
}
