{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "urn:foi-o:schema:empirical-source-population:0.1.0",
  "$defs": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}},
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "manifest_id", "status", "empirical_evidence", "repository", "repository_revision", "snapshot_sha256", "rights_review_path", "rights_review_sha256", "coverage_start", "coverage_end", "created_at", "approved_by", "approved_at", "records"],
  "properties": {
    "schema_version": {"const": "foi-o.empirical-source-population.v0.1.0"}, "manifest_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["candidate_contract_fixture", "rights_approved_frozen"]}, "empirical_evidence": {"type": "boolean"},
    "repository": {"type": "string", "minLength": 1}, "repository_revision": {"type": "string", "pattern": "^[a-f0-9]{40}$"}, "snapshot_sha256": {"$ref": "#/$defs/sha256"},
    "rights_review_path": {"type": "string", "minLength": 1}, "rights_review_sha256": {"$ref": "#/$defs/sha256"},
    "coverage_start": {"type": "string", "format": "date"}, "coverage_end": {"type": "string", "format": "date"}, "created_at": {"type": "string", "format": "date-time"},
    "approved_by": {"type": ["string", "null"], "pattern": "^human:[A-Za-z0-9._-]+$"}, "approved_at": {"type": ["string", "null"], "format": "date-time"},
    "records": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["source_artifact_sha256", "request_linkage_key_sha256", "observed_date", "source_state", "stratum", "rights_eligible", "exclusion_reason"], "properties": {"source_artifact_sha256": {"$ref": "#/$defs/sha256"}, "request_linkage_key_sha256": {"$ref": "#/$defs/sha256"}, "observed_date": {"type": "string", "format": "date"}, "source_state": {"type": "string", "minLength": 1}, "stratum": {"type": "string", "minLength": 1}, "rights_eligible": {"type": "boolean"}, "exclusion_reason": {"type": ["string", "null"], "minLength": 1}}, "allOf": [{"if": {"properties": {"rights_eligible": {"const": true}}}, "then": {"properties": {"exclusion_reason": {"const": null}}}, "else": {"properties": {"exclusion_reason": {"type": "string", "minLength": 1}}}}]}}
  },
  "allOf": [{"if": {"properties": {"status": {"const": "rights_approved_frozen"}}}, "then": {"properties": {"empirical_evidence": {"const": true}, "approved_by": {"type": "string"}, "approved_at": {"type": "string", "format": "date-time"}}}, "else": {"properties": {"empirical_evidence": {"const": false}, "approved_by": {"const": null}, "approved_at": {"const": null}}}}]
}
