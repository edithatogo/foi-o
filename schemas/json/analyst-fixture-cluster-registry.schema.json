  "properties": {"schema_version": {"const": "foi-o.analyst-fixture-cluster-registry.v0.1.0"}, "registry_id": {"type": "string", "minLength": 1}, "status": {"const": "locked_local_fixture_clusters"}, "local_only": {"const": true}, "empirical_evidence": {"const": false}, "human_reviewed": {"const": false}, "gold_eligible": {"const": false}, "release_qualifying": {"const": false}, "publication_eligible": {"const": false}, "unit_manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "algorithm": {"type": "object", "additionalProperties": false, "required": ["name", "version", "threshold"], "properties": {"name": {"const": "exact_redacted_context_sha256"}, "version": {"const": "1"}, "threshold": {"const": 1.0}}}, "created_at": {"type": "string", "format": "date-time"}, "locked_at": {"type": "string", "format": "date-time"}, "clusters": {"type": "array", "minItems": 11, "maxItems": 11, "uniqueItems": true, "items": {"type": "object", "additionalProperties": false, "required": ["cluster_id", "member_unit_sha256", "split"], "properties": {"cluster_id": {"type": "string", "minLength": 1}, "member_unit_sha256": {"type": "array", "minItems": 1, "maxItems": 1, "items": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}, "split": {"const": "annotation_only"}}}}}
