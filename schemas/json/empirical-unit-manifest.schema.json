{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:foi-o:schema:empirical-unit-manifest:0.1.0",
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "unit": {
      "type": "object", "additionalProperties": false,
      "required": ["unit_sha256", "source_artifact_sha256", "source_span", "request_linkage_key_sha256", "duplicate_cluster_id", "split", "stratum", "sample_component", "inclusion_probability", "sampling_weight", "accessibility", "rights_eligible"],
      "properties": {
        "unit_sha256": {"$ref": "#/$defs/sha256"}, "source_artifact_sha256": {"$ref": "#/$defs/sha256"}, "request_linkage_key_sha256": {"$ref": "#/$defs/sha256"},
        "source_span": {"type": "object", "additionalProperties": false, "required": ["start", "end", "coordinate_system"], "properties": {"start": {"type": "integer", "minimum": 0}, "end": {"type": "integer", "minimum": 1}, "coordinate_system": {"const": "utf8_character_half_open"}}},
        "duplicate_cluster_id": {"type": "string", "minLength": 1}, "split": {"enum": ["exploration", "train", "validation", "test", "annotation_only"]}, "stratum": {"type": "string", "minLength": 1},
        "sample_component": {"enum": ["probability", "rare_event_enrichment"]}, "inclusion_probability": {"type": ["number", "null"], "exclusiveMinimum": 0, "maximum": 1}, "sampling_weight": {"type": ["number", "null"], "exclusiveMinimum": 0},
        "accessibility": {"enum": ["accessible", "inaccessible_after_freeze"]}, "rights_eligible": {"type": "boolean"}
      },
      "allOf": [
        {"if": {"properties": {"sample_component": {"const": "probability"}}}, "then": {"properties": {"inclusion_probability": {"type": "number", "exclusiveMinimum": 0, "maximum": 1}, "sampling_weight": {"type": "number", "exclusiveMinimum": 0}}}, "else": {"properties": {"inclusion_probability": {"const": null}, "sampling_weight": {"const": null}}}}
      ]
    }
  },
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "manifest_id", "status", "empirical_evidence", "source_population_manifest_sha256", "sampling_protocol_sha256", "sampling_configuration_sha256", "created_at", "frozen_at", "units"],
  "properties": {
    "schema_version": {"const": "foi-o.empirical-unit-manifest.v0.1.0"}, "manifest_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["candidate_contract_fixture", "frozen"]}, "empirical_evidence": {"type": "boolean"},
    "source_population_manifest_sha256": {"$ref": "#/$defs/sha256"}, "sampling_protocol_sha256": {"$ref": "#/$defs/sha256"}, "sampling_configuration_sha256": {"$ref": "#/$defs/sha256"},
    "created_at": {"type": "string", "format": "date-time"}, "frozen_at": {"type": ["string", "null"], "format": "date-time"},
    "units": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/unit"}}
  },
  "allOf": [
    {"if": {"properties": {"status": {"const": "frozen"}}}, "then": {"properties": {"empirical_evidence": {"const": true}, "frozen_at": {"type": "string", "format": "date-time"}, "units": {"items": {"properties": {"rights_eligible": {"const": true}}}}}}, "else": {"properties": {"empirical_evidence": {"const": false}, "frozen_at": {"const": null}}}}
  ]
}
