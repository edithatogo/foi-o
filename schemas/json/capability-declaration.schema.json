{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/foio-nz/schemas/capability-declaration.schema.json",
  "title": "FOI-O Consumer Capability Declaration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "consumer_id", "capabilities"],
  "properties": {
    "schema_version": {
      "const": "foi-o-nz.capability-declaration.v0.1.0"
    },
    "consumer_id": {"type": "string", "minLength": 1},
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/contractCapability"}
    }
  },
  "$defs": {
    "contractCapability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract_id", "supported_versions", "unknown_version_behavior"],
      "properties": {
        "contract_id": {"type": "string", "minLength": 1},
        "supported_versions": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "unknown_version_behavior": {
          "enum": ["reject", "retain_with_warning"]
        }
      }
    }
  }
}
