{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:foi-o:schema:bounded-pilot-evidence-manifest:0.1.0",
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "span": {"type": "object", "additionalProperties": false, "required": ["start", "end"], "properties": {"start": {"type": "integer", "minimum": 0}, "end": {"type": "integer", "minimum": 1}}},
    "block": {"type": "object", "additionalProperties": false, "required": ["event_pointer", "direction", "element_id", "wrapper_span", "wrapper_sha256", "text_span", "text_sha256"], "properties": {"event_pointer": {"type": "string", "pattern": "^/info_request_events/[0-9]+$"}, "direction": {"enum": ["incoming", "outgoing"]}, "element_id": {"type": "string", "pattern": "^(incoming|outgoing)-[0-9]+$"}, "wrapper_span": {"$ref": "#/$defs/span"}, "wrapper_sha256": {"$ref": "#/$defs/sha"}, "text_span": {"$ref": "#/$defs/span"}, "text_sha256": {"$ref": "#/$defs/sha"}}},
    "attachment": {"type": "object", "additionalProperties": false, "required": ["inventory_pointer", "relative_path", "sha256", "size", "response_message_id"], "properties": {"inventory_pointer": {"type": "string", "pattern": "^/[0-9]+$"}, "relative_path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha"}, "size": {"type": "integer", "minimum": 1}, "response_message_id": {"type": "integer", "minimum": 1}}}
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "manifest_id", "status", "sample_approval_sha256", "request_ids", "selection_method", "records", "local_only", "restricted_content_committed", "authentic_input", "empirical_evidence", "context_presentation_allowed", "execution_allowed"],
  "properties": {
    "schema_version": {"const": "foi-o.bounded-pilot-evidence-manifest.v0.1.0"},
    "manifest_id": {"const": "bounded-pilot-evidence-11872-35076"},
    "status": {"const": "pending_freeze_and_execution_authorization"},
    "sample_approval_sha256": {"const": "f6fde49c1e39d86614497b91eeb579ffab8ccdd27e9119b802c54893734036d9"},
    "request_ids": {"const": ["11872", "35076"]},
    "selection_method": {"type": "object", "additionalProperties": false, "required": ["version", "offsets", "correspondence_rule", "attachment_rule"], "properties": {"version": {"const": "event_dom_bidirectional_census_v1"}, "offsets": {"const": "unicode_code_points_half_open_strict_utf8"}, "correspondence_rule": {"const": "all_message_bearing_events_bijectively_joined_to_top_level_div.correspondence.box_by_direction_and_message_id"}, "attachment_rule": {"const": "census_all_pinned_attachments_json_entries_verified_against_snapshot_manifest"}}},
    "records": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "object", "additionalProperties": false, "required": ["request_id", "snapshot_manifest_sha256", "request_json_sha256", "page_html_sha256", "raw_state", "correspondence", "attachments"], "properties": {"request_id": {"enum": ["11872", "35076"]}, "snapshot_manifest_sha256": {"$ref": "#/$defs/sha"}, "request_json_sha256": {"$ref": "#/$defs/sha"}, "page_html_sha256": {"$ref": "#/$defs/sha"}, "raw_state": {"type": "object", "additionalProperties": false, "required": ["json_pointer", "coordinate_system", "span", "text_sha256", "repeated_elsewhere"], "properties": {"json_pointer": {"const": "/described_state"}, "coordinate_system": {"const": "unicode_code_points_half_open"}, "span": {"$ref": "#/$defs/span"}, "text_sha256": {"$ref": "#/$defs/sha"}, "repeated_elsewhere": {"const": true}}}, "correspondence": {"type": "object", "additionalProperties": false, "required": ["block_count", "blocks", "status_only_events_excluded"], "properties": {"block_count": {"type": "integer", "minimum": 1}, "blocks": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/block"}}, "status_only_events_excluded": {"const": true}}}, "attachments": {"type": "object", "additionalProperties": false, "required": ["inventory_sha256", "verified_empty", "canonical_inventory_empty", "supplemental_file_count", "files"], "properties": {"inventory_sha256": {"$ref": "#/$defs/sha"}, "verified_empty": {"type": "boolean"}, "canonical_inventory_empty": {"type": "boolean"}, "supplemental_file_count": {"type": "integer", "minimum": 0}, "files": {"type": "array", "items": {"$ref": "#/$defs/attachment"}}}}}}},
    "local_only": {"const": true},
    "restricted_content_committed": {"const": false},
    "authentic_input": {"const": true},
    "empirical_evidence": {"const": false},
    "context_presentation_allowed": {"const": false},
    "execution_allowed": {"const": false}
  }
}
