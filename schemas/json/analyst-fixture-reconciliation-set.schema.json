{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:foi-o:schema:analyst-fixture-reconciliation-set:0.1.0",
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "pin": {"type": "object", "additionalProperties": false, "required": ["path", "sha256"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha256"}}},
    "runtime": {"type": "object", "additionalProperties": false, "required": ["provider", "model", "prompt_sha256", "session_id"], "properties": {"provider": {"const": "OpenAI"}, "model": {"const": "Codex / GPT-5; exact snapshot unavailable"}, "prompt_sha256": {"const": "80770f3b4335b7fb5b092a96265e41cef29f0c26081ae46afc9949b220661081"}, "session_id": {"const": "/root/fixture_reconciler_ready"}}},
    "reconciler": {"type": "object", "additionalProperties": false, "required": ["actor_id", "actor_class", "role", "runtime"], "properties": {"actor_id": {"const": "agent:reconciler-fixture"}, "actor_class": {"const": "automated_agent"}, "role": {"const": "reconciler"}, "runtime": {"$ref": "#/$defs/runtime"}}},
    "span": {"type": "object", "additionalProperties": false, "required": ["start", "end", "coordinate_system"], "properties": {"start": {"type": "integer", "minimum": 0}, "end": {"type": "integer", "minimum": 1}, "coordinate_system": {"const": "utf8_character_half_open"}}},
    "analysis_ref": {"type": "object", "additionalProperties": false, "required": ["analyst_id", "sha256", "locked_at"], "properties": {"analyst_id": {"enum": ["agent:analyst-fixture-a", "agent:analyst-fixture-b"]}, "sha256": {"$ref": "#/$defs/sha256"}, "locked_at": {"type": "string", "format": "date-time"}}},
    "record": {"type": "object", "additionalProperties": false, "required": ["schema_version", "record_id", "status", "unit_sha256", "analysis_refs", "reconciler", "outcome", "reconciled_candidate_label", "reconciled_candidate_span", "rationale", "created_at", "locked_at", "empirical_evidence", "human_reviewed", "gold_eligible"], "properties": {"schema_version": {"const": "foi-o.analyst-reconciliation-record.v0.1.0"}, "record_id": {"type": "string", "pattern": "^reconciler-fixture:(pm-[0-9]{2}|tl-[0-9]{2})$"}, "status": {"const": "locked_agent_reconciliation"}, "unit_sha256": {"$ref": "#/$defs/sha256"}, "analysis_refs": {"type": "array", "prefixItems": [{"$ref": "#/$defs/analysis_ref"}, {"$ref": "#/$defs/analysis_ref"}], "items": false, "minItems": 2, "maxItems": 2}, "reconciler": {"$ref": "#/$defs/reconciler"}, "outcome": {"enum": ["resolved", "unresolved"]}, "reconciled_candidate_label": {"type": ["string", "null"]}, "reconciled_candidate_span": {"oneOf": [{"$ref": "#/$defs/span"}, {"type": "null"}]}, "rationale": {"type": "string", "minLength": 10}, "created_at": {"type": "string", "format": "date-time"}, "locked_at": {"type": "string", "format": "date-time"}, "empirical_evidence": {"const": false}, "human_reviewed": {"const": false}, "gold_eligible": {"const": false}}, "allOf": [{"if": {"properties": {"outcome": {"const": "unresolved"}}}, "then": {"properties": {"reconciled_candidate_label": {"const": null}, "reconciled_candidate_span": {"const": null}}}, "else": {"properties": {"reconciled_candidate_label": {"type": "string", "minLength": 1}}}}]},
    "entry": {"type": "object", "additionalProperties": false, "required": ["unit_id", "record_sha256", "record"], "properties": {"unit_id": {"pattern": "^(pm-[0-9]{2}|tl-[0-9]{2})$"}, "record_sha256": {"$ref": "#/$defs/sha256"}, "record": {"$ref": "#/$defs/record"}}}
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "set_id", "status", "analysis_lock", "analysis_sets", "context_presentation", "codebook", "authorization", "reconciler", "disagreement_definition", "unit_count", "disagreement_count", "ordered_disagreement_unit_ids", "ordered_disagreement_commitment_sha256", "record_hash_algorithm", "entries", "local_only", "empirical_evidence", "human_reviewed", "gold_eligible", "release_qualifying", "publication_eligible", "prohibited_actions"],
  "properties": {
    "schema_version": {"const": "foi-o.analyst-fixture-reconciliation-set.v0.1.0"},
    "set_id": {"const": "local-fixture-reconciliation"},
    "status": {"const": "locked_agent_reconciliation_set"},
    "analysis_lock": {"$ref": "#/$defs/pin"},
    "analysis_sets": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"$ref": "#/$defs/pin"}},
    "context_presentation": {"$ref": "#/$defs/pin"},
    "codebook": {"$ref": "#/$defs/pin"},
    "authorization": {"$ref": "#/$defs/pin"},
    "reconciler": {"$ref": "#/$defs/reconciler"},
    "disagreement_definition": {"const": "label_span_or_abstention_differs_v1"},
    "unit_count": {"const": 11},
    "disagreement_count": {"const": 2},
    "ordered_disagreement_unit_ids": {"const": ["pm-06", "tl-02"]},
    "ordered_disagreement_commitment_sha256": {"$ref": "#/$defs/sha256"},
    "record_hash_algorithm": {"const": "sha256_canonical_json_utf8_sort_keys_compact_v1"},
    "entries": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"$ref": "#/$defs/entry"}},
    "local_only": {"const": true},
    "empirical_evidence": {"const": false},
    "human_reviewed": {"const": false},
    "gold_eligible": {"const": false},
    "release_qualifying": {"const": false},
    "publication_eligible": {"const": false},
    "prohibited_actions": {"const": ["redistribution", "publication", "training", "fine_tuning", "release", "dataset_publication", "gold_promotion", "legal_certification", "paper_update", "human_reviewed_claims", "empirical_evidence_claims"]}
  }
}
