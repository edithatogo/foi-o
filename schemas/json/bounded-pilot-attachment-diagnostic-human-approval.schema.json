{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:foi-o:schema:bounded-pilot-attachment-diagnostic-human-approval:0.1.0",
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "approved_by", "approved_on", "approval_statement", "approval_statement_sha256", "approved_request", "bound_scope", "prohibited_actions"],
  "properties": {
    "schema_version": {"const": "foi-o.bounded-pilot-attachment-diagnostic-human-approval.v0.1.0"},
    "approved_by": {"const": "human:edithatogo"},
    "approved_on": {"type": "string", "minLength": 1},
    "approval_statement": {"type": "string", "minLength": 1},
    "approval_statement_sha256": {"$ref": "#/$defs/sha"},
    "approved_request": {
      "const": {
        "path": "examples/v2/bounded-pilot-attachment-stderr-diagnostic-request.pending.json",
        "sha256": "b8c16f51f86b4d1a462edf495dc309f4f6e1dd09c47fb55010a5d08955c40d7f"
      }
    },
    "bound_scope": {
      "const": {
