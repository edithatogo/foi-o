{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:foi-o:schema:empirical:authority-identity-record:0.1.0",
  "title": "FOI-O authority identity record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "authority_identity_id",
    "canonical_name",
    "jurisdiction",
    "active_time",
    "names",
    "platform_identifiers",
    "identity_source_ids",
    "observed_at",
    "review_status",
    "identity_conflict"
  ],
  "properties": {
    "authority_identity_id": {
      "type": "string",
      "minLength": 1
    },
    "canonical_name": {
      "type": "string",
      "minLength": 1
    },
    "jurisdiction": {
      "type": "string",
      "minLength": 1
    },
    "authority_types": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "active_time": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from"
      ],
      "properties": {
        "from": {
          "type": "string",
          "format": "date"
        },
        "to": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        }
      }
    },
    "names": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "valid_from",
          "source_ids"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "valid_from": {
            "type": "string",
            "format": "date"
          },
          "valid_to": {
            "type": [
              "string",
              "null"
            ],
            "format": "date"
          },
          "name_type": {
            "enum": [
              "official",
              "former_official",
              "platform_display",
              "abbreviation",
              "alternate"
            ]
          },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "platform_identifiers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "platform",
          "identifier",
          "valid_from"
        ],
        "properties": {
          "platform": {
            "type": "string",
            "minLength": 1
          },
          "identifier": {
            "type": "string",
            "minLength": 1
          },
          "valid_from": {
            "type": "string",
            "format": "date"
          },
          "valid_to": {
            "type": [
              "string",
              "null"
            ],
            "format": "date"
          },
          "source_uri": {
            "type": [
              "string",
              "null"
            ],
            "format": "uri"
          }
        }
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "relation",
          "target_authority_identity_id",
          "effective_from",
          "source_ids"
        ],
        "properties": {
          "relation": {
            "enum": [
              "predecessor_of",
              "successor_of",
              "merged_into",
              "split_from",
              "renamed_to",
              "administered_by"
            ]
          },
          "target_authority_identity_id": {
            "type": "string",
            "minLength": 1
          },
          "effective_from": {
            "type": "string",
            "format": "date"
          },
          "effective_to": {
            "type": [
              "string",
              "null"
            ],
            "format": "date"
          },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "identity_source_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "record_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "review_status": {
      "enum": [
        "needs_review",
        "human_reviewed",
        "approved",
        "rejected"
      ]
    },
    "identity_conflict": {
      "type": "boolean"
    },
    "conflict_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "identity_conflict": {
            "const": true
          }
        },
        "required": [
          "identity_conflict"
        ]
      },
      "then": {
        "required": [
          "conflict_notes"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "review_status": {
            "const": "approved"
          }
        },
        "required": [
          "review_status"
        ]
      },
      "then": {
        "required": [
          "record_sha256"
        ]
      }
    }
  ]
}
