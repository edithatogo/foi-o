{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:foi-o:schema:nz-oia-applicability-interval-review:0.1.0",
  "title": "FOI-O NZ OIA applicability interval human review",
  "type": "object",
  "additionalProperties": false,
  "required": [
