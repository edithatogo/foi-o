    "status": {"const": "approved"},
    "reviewer": {"const": "edithatogo"},
    "reviewed_at": {"const": "2026-07-17T03:30:22Z"},
    "candidate_artifact_path": {"const": "mappings/nz-oia-applicability-interval-candidates.yaml"},
    "candidate_artifact_sha256": {"const": "401cd17ae98b4aa7adc51e90f861838c29173ec6165c78ed4f448cd58cd82e83"},
    "interval_count": {"const": 50},
    "review_basis": {
      "const": "Reviewed all inclusive/exclusive boundaries against relevant commencement and amendment evidence."
    },
    "all_boundaries_approved": {"const": true},
    "source_pack_promotion_allowed": {"const": false},
    "prohibited_actions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publication", "release", "dataset_publication",
        "legal_certification_beyond_reviewed_boundaries"
      ],
      "properties": {
        "publication": {"const": false},
        "release": {"const": false},
        "dataset_publication": {"const": false},
        "legal_certification_beyond_reviewed_boundaries": {"const": false}
      }
    }
  }
}
