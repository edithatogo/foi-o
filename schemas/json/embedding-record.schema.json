{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/foi-o-nz/schemas/embedding-record.schema.json",
  "title": "FOI-O NZ Embedding Record",
  "type": "object",
  "required": ["source_id", "kind", "text", "embedding_model", "embedding", "metadata"],
  "additionalProperties": false,
  "properties": {
    "source_id": {"type": "string", "minLength": 1},
    "kind": {"type": "string", "enum": ["request", "event"]},
    "text": {"type": "string"},
    "embedding_model": {"type": "string", "minLength": 1},
    "embedding": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "number"}
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "request_id": {"type": ["string", "integer", "null"]},
        "event_type": {"type": ["string", "null"]},
        "normalised_state": {"type": ["string", "null"]}
      }
    }
  }
}
