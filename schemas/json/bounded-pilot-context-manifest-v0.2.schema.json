{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:foi-o:schema:bounded-pilot-context-manifest:0.2.0",
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "source": {
      "type": "object", "additionalProperties": false,
      "required": ["source_kind", "source_id", "source_sha256", "start", "end", "character_count"],
      "properties": {
        "source_kind": {"enum": ["correspondence", "attachment_derived_text"]},
        "source_id": {"type": "string", "minLength": 1},
        "source_sha256": {"$ref": "#/$defs/sha256"},
        "start": {"type": "integer", "minimum": 0},
        "end": {"type": "integer", "minimum": 1},
        "character_count": {"type": "integer", "minimum": 1}
      }
    },
    "context": {
      "type": "object", "additionalProperties": false,
      "required": ["request_id", "unit_sha256", "context_sha256", "global_start", "global_end", "sources"],
      "properties": {
        "request_id": {"enum": ["11872", "35076"]},
        "unit_sha256": {"$ref": "#/$defs/sha256"},
        "context_sha256": {"$ref": "#/$defs/sha256"},
        "global_start": {"type": "integer", "minimum": 0},
        "global_end": {"type": "integer", "minimum": 1},
        "sources": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/source"}}
      }
    },
    "context_11872": {"allOf": [{"$ref": "#/$defs/context"}, {"properties": {"request_id": {"const": "11872"}, "global_start": {"const": 0}, "sources": {"type": "array", "minItems": 7, "maxItems": 7}}}]},
    "context_35076": {"allOf": [{"$ref": "#/$defs/context"}, {"properties": {"request_id": {"const": "35076"}, "sources": {"type": "array", "minItems": 1, "maxItems": 1}}}]},
    "segment": {
      "type": "object", "additionalProperties": false,
      "required": ["request_id", "segment_id", "source_sha256", "source_kind", "start", "end"],
      "properties": {
        "request_id": {"enum": ["11872", "35076"]},
        "segment_id": {"type": "string", "minLength": 1},
        "source_sha256": {"$ref": "#/$defs/sha256"},
        "source_kind": {"enum": ["correspondence", "attachment_derived_text"]},
        "start": {"type": "integer", "minimum": 0},
        "end": {"type": "integer", "minimum": 1}
      }
    }
  },
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "status", "authorization_sha256", "repository_commit", "request_ids", "contexts", "analyst_context_sha256", "byte_count", "codepoint_count", "segments", "analyst_contexts_identical", "local_only", "reconciliation_allowed", "empirical_result_approved", "publication_allowed"],
  "properties": {
    "schema_version": {"const": "foi-o.bounded-pilot-context-manifest.v0.2.0"},
    "status": {"const": "locked_local_contexts"},
    "authorization_sha256": {"$ref": "#/$defs/sha256"},
    "repository_commit": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "request_ids": {"const": ["11872", "35076"]},
    "contexts": {"type": "array", "prefixItems": [{"$ref": "#/$defs/context_11872"}, {"$ref": "#/$defs/context_35076"}], "items": false, "minItems": 2, "maxItems": 2},
    "analyst_context_sha256": {"$ref": "#/$defs/sha256"},
    "byte_count": {"type": "integer", "minimum": 1},
    "codepoint_count": {"type": "integer", "minimum": 1},
    "segments": {"type": "array", "prefixItems": [{"allOf": [{"$ref": "#/$defs/segment"}, {"properties": {"request_id": {"const": "11872"}}}]}, {"allOf": [{"$ref": "#/$defs/segment"}, {"properties": {"request_id": {"const": "11872"}}}]}, {"allOf": [{"$ref": "#/$defs/segment"}, {"properties": {"request_id": {"const": "11872"}}}]}, {"allOf": [{"$ref": "#/$defs/segment"}, {"properties": {"request_id": {"const": "11872"}}}]}, {"allOf": [{"$ref": "#/$defs/segment"}, {"properties": {"request_id": {"const": "11872"}}}]}, {"allOf": [{"$ref": "#/$defs/segment"}, {"properties": {"request_id": {"const": "11872"}}}]}, {"allOf": [{"$ref": "#/$defs/segment"}, {"properties": {"request_id": {"const": "11872"}}}]}, {"allOf": [{"$ref": "#/$defs/segment"}, {"properties": {"request_id": {"const": "35076"}}}]}], "items": false, "minItems": 8, "maxItems": 8},
    "analyst_contexts_identical": {"const": true},
    "local_only": {"const": true},
    "reconciliation_allowed": {"const": false},
    "empirical_result_approved": {"const": false},
    "publication_allowed": {"const": false}
  }
}
