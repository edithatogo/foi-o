{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/foio-nz/schema/request-profile/0.1.0",
  "title": "FOI-O NZ Request Profile",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "source",
    "request_id",
    "title",
    "authority",
    "source_state"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "foi-o-nz.request-profile.v0.1.0"
    },
    "source": {
      "type": "string"
    },
    "request_id": {
      "type": [
        "string",
        "integer"
      ]
    },
    "url_title": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_url": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "authority": {
      "type": "string",
      "minLength": 1
    },
    "source_state": {
      "type": "string",
      "minLength": 1
    },
    "normalised_state": {
      "type": [
        "string",
        "null"
      ]
    },
    "state_mapping": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "manual",
            "rule",
            "model",
            "hybrid",
            "unknown"
          ]
        },
        "confidence": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "evidence_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "source_provenance": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "input_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_record_id": {
          "type": "string",
          "minLength": 1
        },
        "raw_state_field": {
          "type": "string",
          "enum": [
            "state",
            "source_state",
            "unknown"
          ]
        },
        "raw_state_value": {
          "type": "string"
        },
        "mapping_method": {
          "type": "string",
          "enum": [
            "manual",
            "rule",
            "model",
            "hybrid",
            "unknown"
          ]
        },
        "mapping_confidence": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "evidence_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "source_record_id",
        "raw_state_field",
        "raw_state_value",
        "mapping_method",
        "evidence_id"
      ]
    },
    "first_sent": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "last_updated": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "content_sha256": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "html_captured": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "warc_record_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "legal_clock": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "received_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "decision_due_date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "transfer_due_date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "calculation_method": {
          "type": [
            "string",
            "null"
          ]
        },
        "calendar_source_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "calendar_source_url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "calendar_source_status": {
          "type": [
            "string",
            "null"
          ]
        },
        "calendar_retrieved_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "regional_anniversary_days_included": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "confidence": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
