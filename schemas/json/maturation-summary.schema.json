{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foi-o.nz/schemas/maturation-summary.schema.json",
  "title": "FOI-O NZ maturation summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scope",
    "core_profile_boundary",
    "inventory",
    "maturation_documents",
    "maturation_assets",
    "validation_commands",
    "external_gates",
    "ok",
    "missing_paths"
  ],
  "properties": {
    "schema_version": {
      "const": "foi-o-nz.maturation-summary.v0.1.0"
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "core_profile_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "core",
        "validated_profile",
        "non_nz_validation_status"
      ],
      "properties": {
        "core": {
          "type": "string",
          "minLength": 1
        },
        "validated_profile": {
          "const": "FOI-O NZ"
        },
        "non_nz_validation_status": {
          "const": "design_intent_only"
        }
      }
    },
    "inventory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "json_schema_files",
        "example_files",
        "documentation_files",
        "owl_ontology_files",
        "shacl_files",
        "skos_vocabulary_files",
        "mapping_files",
        "python_test_modules"
      ],
      "properties": {
        "json_schema_files": {
          "type": "integer",
          "minimum": 0
        },
        "example_files": {
          "type": "integer",
          "minimum": 0
        },
        "documentation_files": {
          "type": "integer",
          "minimum": 0
        },
        "owl_ontology_files": {
          "type": "integer",
          "minimum": 0
        },
        "shacl_files": {
          "type": "integer",
          "minimum": 0
        },
        "skos_vocabulary_files": {
          "type": "integer",
          "minimum": 0
        },
        "mapping_files": {
          "type": "integer",
          "minimum": 0
        },
        "python_test_modules": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "maturation_documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/path_status"
      }
    },
    "maturation_assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/path_status"
      }
    },
    "validation_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "external_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ok": {
      "type": "boolean"
    },
    "missing_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "path_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "exists",
        "kind"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "exists": {
          "type": "boolean"
        },
        "kind": {
          "enum": [
            "file",
            "directory"
          ]
        }
      }
    }
  }
}
